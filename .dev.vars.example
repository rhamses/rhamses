# Copy to .dev.vars for local Workers dev (wrangler dev / astro dev com proxy)
# O Wrangler carrega apenas .dev.vars — use este arquivo como modelo e coloque os valores reais em .dev.vars (não commitar).
# No terminal onde roda npm run dev, você deve ver "[Password reset] Enviando email via Resend para ..." se as credenciais estiverem presentes.

BETTER_AUTH_SECRET=your-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:8788
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost,http://localhost:8788

# Resend: "from" deve ser um email de domínio verificado no painel do Resend (Domains).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_FROM=contato@seudominio.com

# R2: bucket_name em wrangler.toml (ex.: demo-bucket) — uploads em /api/upload e /api/media/
