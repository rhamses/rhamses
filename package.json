{
  "name": "edgepress",
  "version": "0.0.1",
  "description": "A CMS WordPress compliant version that runs on the Edge",
  "keywords": [
    "cms",
    "wordpress",
    "cloudflare",
    "vercel",
    "edge"
  ],
  "homepage": "https://github.com/amb1io/edgepress#readme",
  "bugs": {
    "url": "https://github.com/amb1io/edgepress/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amb1io/edgepress.git"
  },
  "license": "ISC",
  "author": "Amb1.io",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "predev": "node scripts/sync-theme-public.mjs",
    "prebuild": "node scripts/sync-theme-public.mjs",
    "dev": "npx astro dev",
    "dev:astrov5": "wrangler types -c wrangler.toml && npm run build && npx wrangler pages dev --port 8787",
    "dev:astro": "wrangler types -c wrangler.toml && astro dev",
    "dev:reset": "rm -rf .wrangler && npm run db:generate && npm run db:migrate:local && npm run db:seed && npm run build && npx wrangler pages dev --port 8787",
    "dev:vite": "vite",
    "wrangler-type": "wrangler types -c wrangler.toml",
    "build": "wrangler types -c wrangler.toml && astro build",
    "postbuild": "node scripts/patch-pages-wrangler.mjs",
    "build:seed": "wrangler types -c wrangler.toml && tsx scripts/build-with-seed.ts && astro build",
    "build:run": "wrangler types -c wrangler.toml && astro build && wrangler dev",
    "build:vite": "tsc && vite build",
    "preview": "astro preview",
    "preview:vite": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "task:env": "cp .env.example .env",
    "task:init": "npm run task:env && npm run db:migrate:local",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "wrangler d1 migrations apply edgepress --local -c wrangler.toml",
    "db:migrate:remote": "wrangler d1 migrations apply edgepress --remote -c wrangler.toml",
    "db:baseline:remote": "wrangler d1 execute edgepress --remote --file=./drizzle/baseline.sql -c wrangler.toml",
    "db:migrate:remote:dev": "wrangler d1 migrations apply edgepress-1 --remote -c wrangler.toml",
    "db:baseline:remote:dev": "wrangler d1 execute edgepress-1 --remote --file=./drizzle/baseline.sql -c wrangler.toml",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed-local.ts",
    "db:seed": "tsx scripts/seed-local.ts",
    "db:seed:generate-sql": "tsx scripts/generate-seed-sql.ts",
    "db:seed:remote": "npm run db:seed:generate-sql && wrangler d1 execute edgepress --remote --file=./drizzle/seed/seed-remote.sql -c wrangler.toml",
    "db:seed:remote:dev": "npm run db:seed:generate-sql && wrangler d1 execute edgepress-1 --remote --file=./drizzle/seed/seed-remote.sql -c wrangler.toml"
  },
  "devDependencies": {
    "@astrojs/compiler-rs": "^0.1.6",
    "@astrojs/react": "^5.0.1",
    "@iconify-json/line-md": "^1.2.14",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.8",
    "sass-embedded": "^1.98.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.5.0",
    "@astrojs/cloudflare": "^13.1.2",
    "@blocknote/core": "^0.46.2",
    "@blocknote/mantine": "^0.46.2",
    "@blocknote/react": "^0.46.2",
    "@blocknote/xl-multi-column": "^0.46.2",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@libsql/client": "^0.15.15",
    "@mantine/core": "^8.3.11",
    "@mantine/hooks": "^8.3.11",
    "@mantine/utils": "^6.0.22",
    "@tailwindcss/vite": "^4.1.18",
    "@types/alpinejs": "^3.13.11",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/drag-drop": "^5.1.0",
    "@uppy/image-editor": "^4.2.0",
    "@uppy/locales": "^5.1.1",
    "@uppy/xhr-upload": "^5.1.1",
    "alpinejs": "^3.15.8",
    "astro": "^6.0.6",
    "@astro-community/astro-embed-vimeo": "^0.3.12",
    "astro-icon": "^1.1.5",
    "better-auth": "^1.4.9",
    "daisyui": "^5.5.17",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "dropzone": "^6.0.0-beta.2",
    "htmx.org": "^2.0.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "wrangler": "^4.56.0"
  }
}
