---
import { eq, inArray } from "drizzle-orm";
import { db } from "../../db/index.ts";
import { user } from "../../db/schema.ts";
import { createEdgepressContent } from "../../core/services/edgepress-content.ts";
import { buildPublicPostPath } from "../../core/services/sitemap-service.ts";
import { stripHtml } from "../../core/services/json-ld-service.ts";
import PostThumbnail from "./PostThumbnail.astro";
import type { PostMediaItem } from "./post-thumbnail-utils.ts";

type PostListItem = {
  id?: number;
  title?: string;
  slug?: string;
  excerpt?: string | null;
  author_id?: string | null;
  published_at?: number | string | null;
  created_at?: number | string | null;
  meta_values?: Record<string, unknown>;
  media?: PostMediaItem[];
};

type Props = {
  locale: string;
  postType: string;
  limit?: number;
  /** Ordenação por data de publicação. Default: "desc" */
  order?: "asc" | "desc";
  status?: "published" | "draft" | "archived" | (string & {});
  className?: string;
  required?: boolean;
};

const {
  locale,
  postType,
  limit = 12,
  order = "desc",
  status = "published",
  className,
  required = true,
} = Astro.props as Props;

const content = createEdgepressContent(Astro.locals as App.Locals, {
  baseUrl: Astro.url.origin,
});

let posts: PostListItem[] = [];

try {
  const list = await content.getListWithDetails<PostListItem>("posts", {
    limit,
    locale,
    filter: {
      post_type: postType,
      status,
    },
    order: "published_at",
    orderDir: order,
  });
  posts = list.items ?? [];
} catch (err) {
  const e = err as { message?: string; stack?: string; status?: number; detail?: unknown };
  console.error("[edgepress][postList] Falha ao carregar lista de posts", {
    postType,
    locale,
    order,
    status,
    limit,
    url: Astro.url.href,
    message: e?.message,
    statusCode: e?.status,
    detail: e?.detail,
    stack: e?.stack,
  });
  if (required) throw err;
}

function postSortTimestamp(post: PostListItem): number {
  const raw = post.published_at ?? post.created_at;
  if (raw == null || raw === "") return 0;
  if (typeof raw === "number") return raw;
  const asNum = parseInt(String(raw), 10);
  if (!Number.isNaN(asNum)) return asNum;
  const d = new Date(String(raw)).getTime();
  return Number.isNaN(d) ? 0 : d;
}

// desc = mais recente primeiro; asc = mais antigo primeiro
posts.sort((a, b) => {
  const diff = postSortTimestamp(a) - postSortTimestamp(b);
  return order === "asc" ? diff : -diff;
});

const authorIds = [
  ...new Set(
    posts
      .map((p) => p.author_id)
      .filter((id): id is string => typeof id === "string" && id.trim() !== ""),
  ),
];

const authorNameById = new Map<string, string>();
if (authorIds.length > 0) {
  const rows = await db
    .select({ id: user.id, name: user.name })
    .from(user)
    .where(inArray(user.id, authorIds));
  for (const row of rows) {
    authorNameById.set(row.id, row.name ?? "");
  }
}

function formatPostDate(ts: number | string | null | undefined): { label: string; iso: string } | null {
  if (ts == null || ts === "") return null;
  const n = typeof ts === "number" ? ts : parseInt(String(ts), 10);
  const d = Number.isNaN(n) ? new Date(String(ts)) : new Date(n);
  if (Number.isNaN(d.getTime())) return null;
  return {
    label: d.toLocaleDateString(locale === "pt-br" ? "pt-BR" : locale, {
      day: "2-digit",
      month: "long",
      year: "numeric",
    }),
    iso: d.toISOString(),
  };
}
---

<ul class={`grid gap-6 sm:grid-cols-2 lg:grid-cols-3 ${className ?? ""}`}>
  {
    posts.map((post) => {
      const title = String(post.title ?? "").trim();
      const slug = String(post.slug ?? "").trim();
      const href = slug ? buildPublicPostPath(slug) : "#";
      const excerpt = stripHtml(String(post.excerpt ?? "")).trim();
      const author =
        (post.author_id && authorNameById.get(post.author_id)) || "—";
      const date = formatPostDate(post.published_at ?? post.created_at);

      return (
        <li class="card bg-base-100 shadow-md overflow-hidden">
          <PostThumbnail
            metaValues={post.meta_values}
            media={post.media}
            alt={title}
            className="aspect-video w-full"
          />
          <div class="card-body gap-2">
            <h2 class="card-title text-lg">{title}</h2>
            {author !== "—" ? (
              <p class="text-sm text-base-content/70">{author}</p>
            ) : null}
            {date ? (
              <time class="text-xs text-base-content/60" datetime={date.iso}>
                {date.label}
              </time>
            ) : null}
            {excerpt ? (
              <p class="text-sm text-base-content/80 line-clamp-3">{excerpt}</p>
            ) : null}
            <div class="card-actions justify-end mt-2">
              <a href={href} class="btn btn-primary btn-sm">
                Saiba mais
              </a>
            </div>
          </div>
        </li>
      );
    })
  }
</ul>
