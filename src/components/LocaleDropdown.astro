---
/**
 * Dropdown reutilizável de locales/idiomas (admin e outros contextos).
 */
import { db } from "../db/index.ts";
import { locales as localesTable, settings } from "../db/schema.ts";
import { eq } from "drizzle-orm";

export interface Props {
  selectedLocaleId?: number | null;
  fieldName?: string;
  required?: boolean;
  cols?: number;
  /** input-sm no trigger (modais e formulários compactos) */
  compact?: boolean;
  /**
   * Quando definido, restringe a lista a estes IDs (ignora leitura isolada de site_locales).
   * Use com `resolveCategoryTranslationLocaleIds` para site + admin.
   */
  allowedLocaleIds?: number[];
}

const {
  selectedLocaleId = null,
  fieldName = "id_locale_code",
  required = false,
  cols = 3,
  compact = false,
  allowedLocaleIds: allowedLocaleIdsProp,
} = Astro.props;

const gridColsClass =
  cols === 1
    ? "grid-cols-1"
    : cols === 2
      ? "grid-cols-2"
      : cols === 3
        ? "grid-cols-3"
        : cols === 4
          ? "grid-cols-4"
          : "grid-cols-3";

const allLocales = await db
  .select({
    id: localesTable.id,
    language: localesTable.language,
    hello_world: localesTable.hello_world,
    locale_code: localesTable.locale_code,
    country: localesTable.country,
  })
  .from(localesTable)
  .orderBy(localesTable.language);

let allowedLocaleIds: number[] | null =
  allowedLocaleIdsProp !== undefined ? allowedLocaleIdsProp : null;

if (allowedLocaleIds === null) {
  try {
    const [row] = await db
      .select({ value: settings.value })
      .from(settings)
      .where(eq(settings.name, "site_locales"))
      .limit(1);
    const raw = String(row?.value ?? "").trim();
    if (raw) {
      const parsed = raw
        .split(",")
        .map((s) => parseInt(s.trim(), 10))
        .filter((n) => !Number.isNaN(n) && n > 0);
      if (parsed.length > 0) allowedLocaleIds = parsed;
    }
  } catch {
    // ignore
  }
}

const allowedSet = allowedLocaleIds ? new Set(allowedLocaleIds) : null;
const filteredLocales = allowedSet
  ? allLocales.filter((l) => allowedSet.has(l.id))
  : allLocales;

const localesJson = JSON.stringify(filteredLocales);
const initialLocaleId = selectedLocaleId ?? "";
const inputClass = compact
  ? "input input-bordered input-sm w-full flex items-center cursor-pointer"
  : "input input-bordered w-full flex items-center cursor-pointer";
---

<div
  class="dropdown w-full locale-dropdown-field"
  data-locales={localesJson}
  data-initial-locale-id={initialLocaleId}
  :class="{ 'dropdown-open': localeDropdownOpen }"
  x-on:click.outside="localeDropdownOpen = false"
  x-data="localeDropdownField"
>
  <input type="hidden" name={fieldName} x-model="selectedLocaleId" required={required || undefined} />
  <label tabindex="0" class={inputClass} @click="toggleDropdown()">
    <span x-show="selectedLocale" class="flex-1 flex items-center gap-2 min-w-0">
      <span x-text="selectedLocale ? getFlagEmoji(selectedLocale.locale_code) : ''"></span>
      <span class="truncate" x-text="selectedLocale ? selectedLocale.language : 'Selecione um idioma'"></span>
    </span>
    <span x-show="!selectedLocale" class="flex-1 text-base-content/50"> Selecione um idioma </span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-5 w-5 shrink-0"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
    </svg>
  </label>
  <div
    tabindex="0"
    class="dropdown-content bg-base-100 rounded-box z-500 w-full border border-base-300 p-2 shadow-lg mt-1 max-h-96 overflow-y-auto"
    x-show="localeDropdownOpen"
    x-transition
    @click.stop
  >
    <div class="w-full mb-2">
      <input
        type="text"
        placeholder="Buscar idioma..."
        class="input input-bordered input-sm w-full"
        x-model="localeSearch"
        @click.stop
        @keydown.escape="localeDropdownOpen = false"
      />
    </div>
    <div class={`grid ${gridColsClass} gap-2`}>
      <template x-for="locale in filteredLocales" :key="locale.id">
        <a
          href="#"
          @click.prevent="selectLocale(locale.id)"
          class="grid grid-cols-[auto_1fr] gap-2 py-2 px-2 items-center rounded hover:bg-base-200 transition-colors"
        >
          <span class="text-2xl shrink-0" x-text="getFlagEmoji(locale.locale_code)"></span>
          <div class="flex flex-col flex-1 min-w-0">
            <span class="font-medium text-sm" x-text="locale.language"></span>
            <span class="text-xs text-base-content/60" x-text="locale.hello_world"></span>
          </div>
        </a>
      </template>
    </div>
    <div
      x-show="filteredLocales.length === 0"
      class="text-base-content/50 text-sm py-2 px-4 text-center col-span-2"
    >
      Nenhum idioma encontrado
    </div>
  </div>
</div>

<script>
  document.addEventListener("alpine:init", () => {
    const win = window as Window & { __localeDropdownFieldRegistered?: boolean };
    if (win.__localeDropdownFieldRegistered) return;
    win.__localeDropdownFieldRegistered = true;

    (window.Alpine as { data: (name: string, fn: () => unknown) => void }).data(
      "localeDropdownField",
      () => ({
      selectedLocaleId: null as number | null,
      localeSearch: "",
      localeDropdownOpen: false,
      locales: [] as {
        id: number;
        language: string;
        hello_world: string;
        locale_code: string;
        country: string;
      }[],
      init() {
        const el = (this as unknown as { $el: HTMLElement }).$el;
        const rawLocales = el.dataset["locales"] ?? "[]";
        try {
          this.locales = JSON.parse(rawLocales);
        } catch {
          this.locales = [];
        }
        const initial = el.dataset["initialLocaleId"];
        if (initial !== undefined && initial !== "") {
          const n = parseInt(initial, 10);
          this.selectedLocaleId = Number.isNaN(n) ? null : n;
        }
      },
      get filteredLocales() {
        if (!this.localeSearch.trim()) return this.locales;
        const search = this.localeSearch.toLowerCase();
        return this.locales.filter(
          (locale) =>
            locale.language.toLowerCase().includes(search) ||
            locale.country.toLowerCase().includes(search) ||
            locale.locale_code.toLowerCase().includes(search) ||
            locale.hello_world.toLowerCase().includes(search),
        );
      },
      get selectedLocale() {
        return this.locales.find((l) => l.id === this.selectedLocaleId);
      },
      selectLocale(localeId: number) {
        this.selectedLocaleId = localeId;
        this.localeSearch = "";
        this.localeDropdownOpen = false;
      },
      toggleDropdown() {
        this.localeDropdownOpen = !this.localeDropdownOpen;
      },
      getFlagEmoji(localeCode: string) {
        const flagMap: Record<string, string> = {
          en: "🇺🇸",
          "en-gb": "🇬🇧",
          "pt-br": "🇧🇷",
          pt_br: "🇧🇷",
          "pt-pt": "🇵🇹",
          es: "🇪🇸",
          "es-mx": "🇲🇽",
          fr: "🇫🇷",
          de: "🇩🇪",
          it: "🇮🇹",
          ja: "🇯🇵",
          ko: "🇰🇷",
        };
        const code = localeCode.toLowerCase().replace(/_/g, "-");
        const baseCode = code.split("-")[0] || code;
        return flagMap[code] || flagMap[baseCode] || "🌐";
      },
    }),
    );
  });
</script>
