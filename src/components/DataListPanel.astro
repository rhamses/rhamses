---
/**
 * Painel reutilizável: barra de filtros (uma por coluna) + DataList.
 */
import DataList from "./DataList.astro";
import ListFilterBar from "./ListFilterBar.astro";
import type { DataListColumn, DataListActionConfig } from "./DataList.astro";
import {
  buildFilterFieldsFromColumns,
  type ListFilterField,
  DEFAULT_EXCLUDED_FILTER_COLUMNS,
} from "../lib/list-utils.ts";

interface Props {
  columns: DataListColumn[];
  items: Record<string, unknown>[];
  action: string;
  hiddenFields?: Record<string, string>;
  filterValues?: Record<string, string>;
  filterFields?: ListFilterField[];
  excludeFilterColumns?: string[];
  filterPlaceholder?: string;
  filterSubmitLabel: string;
  filterClearLabel?: string;
  filterClearHref?: string;
  showFilters?: boolean;
  filterPrefix?: string;
  emptyMessage: string;
  emptyColspan?: number;
  actionConfig?: DataListActionConfig;
  selectable?: boolean;
  selectAllId?: string;
  selectAllLabel?: string;
  selectItemLabel?: (item: Record<string, unknown>) => string;
  actionsColumnLabel?: string;
  editLabel?: string;
  deleteLabel?: string;
  duplicateLabel?: string;
  pagination?: {
    page: number;
    totalPages: number;
    total: number;
    buildPageUrl: (page: number) => string;
  };
  previousLabel?: string;
  nextLabel?: string;
  pageOfText?: string;
}

const {
  columns,
  items,
  action,
  hiddenFields = {},
  filterValues = {},
  filterFields,
  excludeFilterColumns = DEFAULT_EXCLUDED_FILTER_COLUMNS,
  filterPlaceholder,
  filterSubmitLabel,
  filterClearLabel,
  filterClearHref,
  showFilters = true,
  filterPrefix,
  emptyMessage,
  emptyColspan,
  actionConfig,
  selectable,
  selectAllId,
  selectAllLabel,
  selectItemLabel,
  actionsColumnLabel,
  editLabel,
  deleteLabel,
  duplicateLabel,
  pagination,
  previousLabel,
  nextLabel,
  pageOfText,
} = Astro.props;

const resolvedFilterFields =
  filterFields ??
  buildFilterFieldsFromColumns(columns, filterValues, {
    excludeKeys: excludeFilterColumns,
    ...(filterPlaceholder ? { placeholder: filterPlaceholder } : {}),
  });
---

{
  showFilters && resolvedFilterFields.length > 0 && (
    <ListFilterBar
      action={action}
      fields={resolvedFilterFields}
      hiddenFields={hiddenFields}
      submitLabel={filterSubmitLabel}
      {...(filterClearLabel && filterClearHref
        ? { clearLabel: filterClearLabel, clearHref: filterClearHref }
        : {})}
      {...(filterPrefix ? { filterPrefix } : {})}
    />
  )
}

<DataList
  columns={columns}
  items={items}
  emptyMessage={emptyMessage}
  emptyColspan={emptyColspan ?? columns.length + (actionConfig ? 1 : 0)}
  {...(actionConfig ? { actionConfig } : {})}
  {...(selectable ? { selectable } : {})}
  {...(selectAllId ? { selectAllId } : {})}
  {...(selectAllLabel ? { selectAllLabel } : {})}
  {...(selectItemLabel ? { selectItemLabel } : {})}
  {...(actionsColumnLabel ? { actionsColumnLabel } : {})}
  {...(editLabel ? { editLabel } : {})}
  {...(deleteLabel ? { deleteLabel } : {})}
  {...(duplicateLabel ? { duplicateLabel } : {})}
  {...(pagination ? { pagination } : {})}
  {...(previousLabel ? { previousLabel } : {})}
  {...(nextLabel ? { nextLabel } : {})}
  {...(pageOfText ? { pageOfText } : {})}
/>
