---
import type { ListFilterField } from "../lib/list-utils.ts";
import { hasActiveFilters } from "../lib/list-utils.ts";

interface Props {
  action: string;
  fields: ListFilterField[];
  hiddenFields?: Record<string, string>;
  submitLabel: string;
  clearLabel?: string;
  clearHref?: string;
  filterPrefix?: string;
}

const {
  action,
  fields,
  hiddenFields = {},
  submitLabel,
  clearLabel,
  clearHref,
  filterPrefix = "filter_",
} = Astro.props;

const activeFilters = hasActiveFilters(
  Object.fromEntries(fields.map((field) => [field.key, field.value ?? ""])),
);
---

<form method="get" action={action} class="mb-4 flex flex-wrap items-end gap-2">
  {
    Object.entries(hiddenFields).map(([name, value]) => (
      <input type="hidden" name={name} value={value} />
    ))
  }
  <input type="hidden" name="page" value="1" />
  {
    fields.map((field) => (
      <div class="form-control">
        <label class="label py-0">
          <span class="label-text text-xs">{field.label}</span>
        </label>
        <input
          type="text"
          name={field.paramName ?? `${filterPrefix}${field.key}`}
          placeholder={field.placeholder}
          class="input input-bordered input-sm w-32 max-w-full"
          value={field.value ?? ""}
        />
      </div>
    ))
  }
  <button type="submit" class="btn btn-primary btn-sm">{submitLabel}</button>
  {
    clearLabel && clearHref && activeFilters && (
      <a href={clearHref} class="btn btn-ghost btn-sm">
        {clearLabel}
      </a>
    )
  }
</form>
