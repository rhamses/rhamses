---
/**
 * Menu lateral do admin com drawer (recolher/expandir) e blocos colapsáveis.
 */
import { Icon } from "astro-icon/components";
import { t, type Locale } from "../../i18n/index.ts";
import { resolveMenuOption, type MenuItem } from "../../utils/menu.ts";

export interface Props {
  locale: string;
  menuItems: MenuItem[];
}

const { locale, menuItems } = Astro.props;
const currentLocale = locale as Locale;

const adminBase = (path: string) => {
  const cleaned = path.replace(/^\/+/, "");
  if (cleaned === "admin") {
    return `/admin/${currentLocale}`;
  }
  if (cleaned.startsWith("admin/")) {
    const rest = cleaned.slice("admin/".length);
    return `/admin/${currentLocale}/${rest}`;
  }
  return `/admin/${currentLocale}/${cleaned}`;
};

const menuHref = (link: string) => {
  const i = link.indexOf("?");
  if (i === -1) return adminBase(link);
  return adminBase(link.slice(0, i)) + "?" + link.slice(i + 1);
};
---

<aside id="admin-sidebar" class="admin-sidebar" aria-label={t(currentLocale, "admin.sidebar.label")}>
  <div class="admin-sidebar__header">
    <a href={adminBase("admin")} class="admin-sidebar__brand">
      {t(currentLocale, "admin.brand")}
    </a>
    <button
      type="button"
      class="btn btn-ghost btn-sm btn-square admin-sidebar__drawer-toggle"
      data-admin-sidebar-drawer-toggle
      aria-expanded="true"
      aria-label={t(currentLocale, "admin.sidebar.toggleDrawer")}
    >
      <Icon name="line-md:menu-fold-left" size={20} aria-hidden="true" />
    </button>
  </div>
  <nav class="admin-sidebar__nav" aria-label={t(currentLocale, "admin.sidebar.navLabel")}>
    <ul class="admin-sidebar__sections">
      {
        menuItems.map((item) => {
          const parentName =
            t(currentLocale, `postType.${item.postTypeSlug}`) ||
            item.postTypeName;
          const slugMatchingOption = item.menuOptions.find(
            (opt) => opt === item.postTypeSlug,
          );
          const parentLink = slugMatchingOption
            ? resolveMenuOption(
                slugMatchingOption,
                item.postTypeSlug,
                item.postTypeName,
                currentLocale,
                t,
              ).link
            : null;
          const submenuOptions = item.menuOptions.filter(
            (opt) => opt !== item.postTypeSlug,
          );
          const hasSubmenu = submenuOptions.length > 0;

          if (parentLink !== null && !hasSubmenu) {
            return (
              <li>
                <a href={menuHref(parentLink)} class="admin-sidebar__single-link">
                  <Icon name={item.icon} size={20} class="admin-sidebar__section-icon" />
                  <span>{parentName}</span>
                </a>
              </li>
            );
          }

          const panelOptions =
            hasSubmenu
              ? submenuOptions
              : item.menuOptions.length > 0
                ? item.menuOptions
                : [];

          if (panelOptions.length === 0) {
            const first = item.menuOptions[0];
            const resolved = first
              ? resolveMenuOption(
                  first,
                  item.postTypeSlug,
                  item.postTypeName,
                  currentLocale,
                  t,
                )
              : {
                  text: parentName,
                  link: `admin/${item.postTypeSlug}`,
                  icon: "line-md:document",
                };
            return (
              <li>
                <a href={menuHref(resolved.link)} class="admin-sidebar__single-link">
                  <Icon name={item.icon} size={20} class="admin-sidebar__section-icon" />
                  <span>{resolved.text}</span>
                </a>
              </li>
            );
          }

          const firstPanelResolved = resolveMenuOption(
            panelOptions[0],
            item.postTypeSlug,
            item.postTypeName,
            currentLocale,
            t,
          );
          const drawerIconHref = menuHref(firstPanelResolved.link);

          return (
            <li
              class="admin-sidebar__section"
              data-section-slug={item.postTypeSlug}
            >
              <div class="admin-sidebar__section-head">
                <button
                  type="button"
                  class="btn btn-ghost btn-sm btn-square shrink-0 min-h-0 h-8 w-8 p-0"
                  data-admin-sidebar-section-toggle
                  aria-expanded="true"
                  aria-label={t(currentLocale, "admin.sidebar.toggleSection", { name: parentName })}
                >
                  <Icon
                    name="line-md:chevron-down"
                    size={18}
                    class="admin-sidebar__section-chevron"
                    aria-hidden="true"
                  />
                </button>
                <a
                  href={drawerIconHref}
                  class="admin-sidebar__section-drawer-link"
                  aria-label={firstPanelResolved.text}
                  title={firstPanelResolved.text}
                >
                  <Icon name={item.icon} size={20} class="admin-sidebar__section-icon" />
                </a>
                {parentLink !== null ? (
                  <a href={menuHref(parentLink)} class="admin-sidebar__section-link">
                    <Icon name={item.icon} size={20} class="admin-sidebar__section-icon admin-sidebar__section-icon--expanded" />
                    <span class="admin-sidebar__section-label">{parentName}</span>
                  </a>
                ) : (
                  <span class="admin-sidebar__section-link text-base-content/80">
                    <Icon name={item.icon} size={20} class="admin-sidebar__section-icon admin-sidebar__section-icon--expanded" />
                    <span class="admin-sidebar__section-label">{parentName}</span>
                  </span>
                )}
              </div>
              <div class="admin-sidebar__section-panel">
                <ul class="admin-sidebar__submenu">
                  {panelOptions.map((opt) => {
                    const resolved = resolveMenuOption(
                      opt,
                      item.postTypeSlug,
                      item.postTypeName,
                      currentLocale,
                      t,
                    );
                    return (
                      <li>
                        <a href={menuHref(resolved.link)}>
                          <span>{resolved.text}</span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            </li>
          );
        })
      }
    </ul>
  </nav>
</aside>

<script>
  import { bindAdminSidebarInit } from "./admin-sidebar.ts";
  bindAdminSidebarInit();
</script>
