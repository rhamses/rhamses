---
/**
 * Lista de imagens da biblioteca usando cards DaisyUI.
 * Cada item é um MediaLibraryCard. Seleção (radio/checkbox) e borda são controlados por script no MediaManager.
 */
import MediaLibraryCard from "./MediaLibraryCard.astro";

export interface MediaLibraryItem {
  id: number;
  title: string;
  url: string;
  path?: string;
}

export interface Props {
  items: MediaLibraryItem[];
  nameId: string;
  gallery?: boolean;
}

const { items, nameId, gallery = false } = Astro.props;
---

<div class="media-library-list grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3" data-media-library-list>
  {items.map((item) => (
    <MediaLibraryCard
      id={item.id}
      title={item.title}
      url={item.url}
      selected={false}
      gallery={gallery}
      nameId={nameId}
    />
  ))}
</div>
