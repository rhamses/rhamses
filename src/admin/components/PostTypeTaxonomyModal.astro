---
/**
 * Modal para criar tipo de taxonomia customizado (registry taxonomyType).
 * Deve ficar fora do formulário principal de post types (sem form aninhado).
 *
 * - Campo superior: título/chave (`translations.key`, slug automático para o tipo).
 * - Linhas de tradução: valor por locale (`translations_languages.value`).
 */
import { Icon } from "astro-icon/components";
import { eq } from "drizzle-orm";
import { db } from "../../db/index.ts";
import { locales as localesTable } from "../../db/schema.ts";
import LocaleDropdown from "../../components/LocaleDropdown.astro";
import { t, type Locale } from "../../i18n/index.ts";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const currentLocale = locale as Locale;

const adminLocaleCode =
  locale === "pt-br" ? "pt_BR" : locale === "es" ? "es_ES" : "en_US";
let defaultLocaleId: number | null = null;
try {
  const [row] = await db
    .select({ id: localesTable.id })
    .from(localesTable)
    .where(eq(localesTable.locale_code, adminLocaleCode))
    .limit(1);
  defaultLocaleId = row?.id ?? null;
} catch {
  defaultLocaleId = null;
}
---

<input type="checkbox" id="post-type-taxonomy-modal-toggle" class="modal-toggle" />
<div class="modal overflow-visible" role="dialog" aria-labelledby="post-type-taxonomy-modal-title">
  <div class="modal-box max-w-lg overflow-visible">
    <h3 id="post-type-taxonomy-modal-title" class="font-semibold text-lg mb-4">
      {t(currentLocale, "admin.postTypes.addCategory")}
    </h3>
    <div id="post-type-taxonomy-modal-error" class="min-h-6 text-error text-sm"></div>
    <form
      id="post-type-taxonomy-form"
      class="flex flex-col gap-4"
      hx-post="/api/taxonomy-types"
      hx-swap="none"
    >
      <input type="hidden" name="locale" value={locale} />

      <div class="form-control">
        <label for="taxonomy-type-key" class="label py-0">
          <span class="label-text">{t(currentLocale, "admin.postTypes.categoryName")}</span>
        </label>
        <input
          type="text"
          id="taxonomy-type-key"
          name="key"
          required
          class="input input-bordered w-full input-sm"
          placeholder="genero"
        />
        <p class="text-xs text-base-content/50 mt-1">
          {t(currentLocale, "admin.postTypes.categoryKeyHint")}
        </p>
      </div>

      <div>
        <p class="label-text font-medium mb-2">
          {t(currentLocale, "admin.postTypes.translationsSection")}
        </p>
        <div id="taxonomy-type-translation-rows" class="flex flex-col gap-2">
          <div class="taxonomy-type-translation-row grid grid-cols-[minmax(0,11rem)_1fr_2rem] gap-2 items-end">
            <div class="form-control min-w-0">
              <span class="label-text text-xs mb-1 block">
                {t(currentLocale, "admin.postTypes.translationLocale")}
              </span>
              <LocaleDropdown
                fieldName="translation_locale_id[]"
                selectedLocaleId={defaultLocaleId}
                cols={1}
                compact={true}
                required={true}
              />
            </div>
            <div class="form-control min-w-0">
              <label class="label py-0">
                <span class="label-text text-xs">
                  {t(currentLocale, "admin.postTypes.translationValue")}
                </span>
              </label>
              <input
                type="text"
                name="translation_value[]"
                class="input input-bordered input-sm w-full"
                placeholder={t(currentLocale, "admin.postTypes.translationValuePlaceholder")}
              />
            </div>
            <button
              type="button"
              class="btn btn-ghost btn-xs btn-square text-error taxonomy-row-remove shrink-0 self-end mb-1"
              aria-label={t(currentLocale, "admin.postTypes.removeField")}
              disabled
            >
              <Icon name="line-md:trash" size={18} aria-hidden="true" />
            </button>
          </div>
        </div>
        <p class="text-xs text-base-content/50 mt-2">
          {t(currentLocale, "admin.postTypes.translationValueHint")}
        </p>
        <button
          type="button"
          id="taxonomy-type-add-translation-row"
          class="link link-primary link-hover text-sm mt-2"
        >
          {t(currentLocale, "admin.postTypes.addTranslation")}
        </button>
      </div>

      <div class="modal-action mt-2">
        <button type="submit" class="btn btn-primary btn-sm">
          {t(currentLocale, "admin.taxonomy.addButton")}
        </button>
        <label for="post-type-taxonomy-modal-toggle" class="btn btn-ghost btn-sm">
          {t(currentLocale, "admin.content.cancel")}
        </label>
      </div>
    </form>
  </div>
  <label class="modal-backdrop" for="post-type-taxonomy-modal-toggle">
    {t(currentLocale, "admin.taxonomy.modalClose")}
  </label>
</div>

<div id="taxonomy-type-row-template" class="hidden" aria-hidden="true">
  <div class="taxonomy-type-translation-row grid grid-cols-[minmax(0,11rem)_1fr_2rem] gap-2 items-end">
    <div class="form-control min-w-0">
      <span class="label-text text-xs mb-1 block">
        {t(currentLocale, "admin.postTypes.translationLocale")}
      </span>
      <LocaleDropdown fieldName="translation_locale_id[]" cols={1} compact={true} required={true} />
    </div>
    <div class="form-control min-w-0">
      <label class="label py-0">
        <span class="label-text text-xs">
          {t(currentLocale, "admin.postTypes.translationValue")}
        </span>
      </label>
      <input
        type="text"
        name="translation_value[]"
        class="input input-bordered input-sm w-full"
        placeholder={t(currentLocale, "admin.postTypes.translationValuePlaceholder")}
      />
    </div>
    <button
      type="button"
      class="btn btn-ghost btn-xs btn-square text-error taxonomy-row-remove shrink-0 self-end mb-1"
      aria-label={t(currentLocale, "admin.postTypes.removeField")}
    >
      <Icon name="line-md:trash" size={18} aria-hidden="true" />
    </button>
  </div>
</div>

<script>
  import { appendTaxonomyTypeCheckbox } from "../../shared/scripts/post-type-form.ts";

  function closeTaxonomyModal() {
    const toggle = document.getElementById("post-type-taxonomy-modal-toggle") as HTMLInputElement | null;
    if (toggle) toggle.checked = false;
  }

  function showTaxonomyModalError(message: string) {
    const err = document.getElementById("post-type-taxonomy-modal-error");
    if (err) err.innerHTML = `<p class="text-error text-sm">${message}</p>`;
    const toggle = document.getElementById("post-type-taxonomy-modal-toggle") as HTMLInputElement | null;
    if (toggle) toggle.checked = true;
  }

  function resetTaxonomyModalForm() {
    const form = document.getElementById("post-type-taxonomy-form") as HTMLFormElement | null;
    form?.reset();
    const err = document.getElementById("post-type-taxonomy-modal-error");
    if (err) err.innerHTML = "";
    const container = document.getElementById("taxonomy-type-translation-rows");
    const templateWrap = document.getElementById("taxonomy-type-row-template");
    const templateRow = templateWrap?.querySelector(".taxonomy-type-translation-row");
    if (container && templateRow) {
      container.innerHTML = "";
      const row = templateRow.cloneNode(true) as HTMLElement;
      clearTranslationRow(row);
      container.appendChild(row);
      const removeBtn = row.querySelector(".taxonomy-row-remove") as HTMLButtonElement | null;
      if (removeBtn) removeBtn.disabled = true;
      initAlpineOn(row);
    }
  }

  function clearTranslationRow(row: HTMLElement) {
    row.querySelectorAll('input[type="text"]').forEach((input) => {
      (input as HTMLInputElement).value = "";
    });
    const dropdown = row.querySelector(".locale-dropdown-field") as HTMLElement | null;
    if (dropdown) {
      dropdown.dataset["initialLocaleId"] = "";
      const hidden = dropdown.querySelector('input[type="hidden"]') as HTMLInputElement | null;
      if (hidden) hidden.value = "";
    }
  }

  function initAlpineOn(root: HTMLElement) {
    const alpine = (window as unknown as { Alpine?: { initTree: (el: HTMLElement) => void } }).Alpine;
    if (alpine?.initTree) alpine.initTree(root);
  }

  function bindRemoveButtons(container: HTMLElement) {
    const rows = container.querySelectorAll(".taxonomy-type-translation-row");
    rows.forEach((row) => {
      const btn = row.querySelector(".taxonomy-row-remove") as HTMLButtonElement | null;
      if (!btn) return;
      btn.disabled = rows.length <= 1;
      btn.onclick = () => {
        if (container.querySelectorAll(".taxonomy-type-translation-row").length <= 1) return;
        row.remove();
        bindRemoveButtons(container);
      };
    });
  }

  function handleTaxonomyTypeAdded(detail: { type?: string; label?: string }) {
    if (!detail?.type) return;
    appendTaxonomyTypeCheckbox(detail.type, detail.label ?? detail.type);
    closeTaxonomyModal();
    resetTaxonomyModalForm();
  }

  function parseHtmxTrigger(header: string | null): Record<string, unknown> | null {
    if (!header) return null;
    try {
      return JSON.parse(header) as Record<string, unknown>;
    } catch {
      return null;
    }
  }

  document.getElementById("taxonomy-type-add-translation-row")?.addEventListener("click", () => {
    const container = document.getElementById("taxonomy-type-translation-rows");
    const templateWrap = document.getElementById("taxonomy-type-row-template");
    const templateRow = templateWrap?.querySelector(".taxonomy-type-translation-row");
    if (!container || !templateRow) return;
    const row = templateRow.cloneNode(true) as HTMLElement;
    clearTranslationRow(row);
    container.appendChild(row);
    initAlpineOn(row);
    bindRemoveButtons(container);
  });

  const rowsContainer = document.getElementById("taxonomy-type-translation-rows");
  if (rowsContainer) bindRemoveButtons(rowsContainer);

  document.body.addEventListener("taxonomy-type-added", (ev: Event) => {
    handleTaxonomyTypeAdded((ev as CustomEvent<{ type?: string; label?: string }>).detail ?? {});
  });

  const taxonomyForm = document.getElementById("post-type-taxonomy-form");
  taxonomyForm?.addEventListener("htmx:afterRequest", (ev: Event) => {
    const evt = ev as CustomEvent & {
      detail?: { successful?: boolean; elt?: HTMLElement; xhr?: XMLHttpRequest };
    };
    const detail = evt.detail;
    if (detail?.elt?.id !== "post-type-taxonomy-form") return;

    if (!detail.successful) {
      try {
        const data = JSON.parse(detail.xhr?.responseText ?? "{}") as { error?: string };
        showTaxonomyModalError(
          typeof data.error === "string" ? data.error : "Erro ao adicionar categoria.",
        );
      } catch {
        showTaxonomyModalError("Erro ao adicionar categoria.");
      }
      return;
    }

    const trigger = parseHtmxTrigger(detail.xhr?.getResponseHeader("HX-Trigger") ?? null);
    const added = trigger?.["taxonomy-type-added"] as { type?: string; label?: string } | undefined;

    if (added?.type) {
      handleTaxonomyTypeAdded(added);
      return;
    }

    try {
      const data = JSON.parse(detail.xhr?.responseText ?? "{}") as {
        success?: boolean;
        item?: { type: string; label: string };
      };
      if (data.success && data.item) {
        handleTaxonomyTypeAdded(data.item);
      }
    } catch {
      // ignore
    }
  });
</script>

<style>
  #post-type-taxonomy-form .dropdown {
    position: relative;
    z-index: 30;
  }
  #post-type-taxonomy-form .dropdown:focus-within,
  #post-type-taxonomy-form .dropdown.dropdown-open {
    z-index: 200;
  }
</style>
