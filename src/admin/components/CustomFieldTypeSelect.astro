---
/**
 * Select "Tipo de dados" com opções Texto e Arquivo.
 * Reutilizado na modal (novo campo) e nas linhas "adicionar mais dados".
 * Encaminhe x-model para binding (ex.: x-model="row.type").
 */
interface Props {
  class?: string;
  [key: string]: unknown;
}
const { class: className, ...rest } = Astro.props as Props;
---
<select
  class={`select select-bordered select-sm w-full max-w-xs ${className ?? ""}`.trim()}
  aria-label="Tipo de dados"
  {...rest}
>
  <option value="">-- Selecione --</option>
  <option value="text">Texto</option>
  <option value="editor">Editor de texto</option>
  <option value="file">Arquivo</option>
</select>
