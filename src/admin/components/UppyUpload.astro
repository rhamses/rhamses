---
/**
 * Componente reutilizável do Uppy para upload de arquivos.
 * Suporta dois modos:
 * - "new": Upload múltiplo, não auto-procede, cria posts automaticamente após upload
 * - "edit": Upload único, auto-procede, não cria posts automaticamente
 */
import type { Locale } from "../../i18n/index.ts";
import MediaManager from "./MediaManager.astro";

export interface Props {
  /** ID único do container do Uppy */
  containerId: string;
  /** Locale para traduções */
  locale: Locale;
  /** Modo de operação: "new" ou "edit" */
  mode: "new" | "edit";
  /** Altura do dashboard (padrão: 400 para edit, calculado para new) */
  height?: number;
  /** Nome do evento customizado disparado após upload (padrão: "attachment-uploaded") */
  eventName?: string;
  /** Se true, oculta o botão de upload no dashboard (útil para edit mode) */
  hideUploadButton?: boolean;
  /** Se true, limpa os arquivos após completar upload (padrão: true para new, false para edit) */
  clearOnComplete?: boolean;
  /** Classe CSS adicional para o container */
  containerClass?: string;
  /** Nome do evento disparado ao concluir (fechar painel após "Concluído") */
  completeEventName?: string;
  /** Se true, mostra o link "selecione da biblioteca" e abre MediaManager em modal (padrão: true) */
  showLibraryLink?: boolean;
  /** Se true, MediaManager usa checkbox (múltipla seleção); se false, radio (padrão: false) */
  mediaManagerGallery?: boolean;
}

const {
  containerId,
  locale: localeProp,
  mode,
  height,
  eventName = "attachment-uploaded",
  hideUploadButton = mode === "edit",
  clearOnComplete = mode === "new",
  containerClass = "",
  completeEventName,
  showLibraryLink = true,
  mediaManagerGallery = false,
} = Astro.props;

const currentLocale = localeProp;
const modalId = `media-manager-modal-${containerId}`;
---

<div class="uppy-upload-with-library w-full" data-uppy-wrapper data-container-id={containerId}>
  <div
    id={containerId}
    class={`uppy-container ${containerClass}`}
    data-container-id={containerId}
    data-current-locale={currentLocale}
    data-mode={mode}
    data-height={height ?? ""}
    data-event-name={eventName}
    data-hide-upload-button={hideUploadButton}
    data-clear-on-complete={clearOnComplete}
    data-complete-event-name={completeEventName ?? ""}
  ></div>

  {showLibraryLink && (
    <p class="text-center mt-3">
      <button
        type="button"
        class="link link-primary text-sm"
        data-media-library-open
        data-target-modal={modalId}
      >
        selecione da biblioteca
      </button>
    </p>
  )}

  {showLibraryLink && (
    <div
      id={modalId}
      class="media-manager-modal hidden fixed inset-0 z-50 p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="media-manager-title"
      data-media-manager-modal
    >
      <div
        class="media-manager-modal-backdrop absolute inset-0 bg-black/50"
        data-media-manager-modal-close
        tabindex="-1"
      ></div>
      <div class="media-manager-modal-content relative bg-base-100 rounded-lg shadow-xl w-[80vw] h-[80vh] max-w-[80vw] max-h-[80vh] overflow-hidden flex flex-col p-4">
        <MediaManager gallery={mediaManagerGallery} />
      </div>
    </div>
  )}
</div>

<style>
  .uppy-container {
    width: 100%;
    max-width: 100%;
  }
  .uppy-container :global(.uppy-Dashboard),
  .uppy-container :global(.uppy-Dashboard-inner) {
    width: 100% !important;
    max-width: 100% !important;
  }
  .media-manager-modal {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .media-manager-modal.hidden {
    display: none !important;
  }
</style>

<script>
  // Import será processado pelo bundler do Astro automaticamente
  // O Astro processa scripts sem type="module" e adiciona type="module" automaticamente
  import { initUppyInstance } from "../../infra/media/uppy-init.ts";
  
  // Encontrar todos os elementos uppy-container e inicializar
  function initAllUppyInstances() {
    const containers = document.querySelectorAll(".uppy-container[data-container-id]");
    containers.forEach((container) => {
      const containerId = container.id || container.getAttribute("data-container-id");
      if (!containerId) return;
      
      const element = document.getElementById(containerId);
      if (!element) return;
      // @ts-ignore - propriedade dinâmica adicionada pelo Uppy
      if (element.__uppy) return;

      const currentLocale = element.dataset["currentLocale"] || "pt-br";
      const mode = (element.dataset["mode"] || "new") === "edit" ? "edit" : "new";
      const height = element.dataset["height"] ? parseInt(element.dataset["height"], 10) : null;
      const eventName = element.dataset["eventName"] || "attachment-uploaded";
      const hideUploadButton = element.dataset["hideUploadButton"] === "true";
      const clearOnComplete = element.dataset["clearOnComplete"] === "true";
      const completeEventName = element.dataset["completeEventName"] || undefined;

      initUppyInstance({
        containerId,
        currentLocale,
        mode,
        height,
        eventName,
        hideUploadButton,
        clearOnComplete,
        ...(completeEventName ? { completeEventName } : {}),
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAllUppyInstances);
  } else {
    setTimeout(initAllUppyInstances, 100);
  }

  function setupMediaManagerModals() {
    document.querySelectorAll("[data-media-library-open]").forEach((btn) => {
      const modalId = btn.getAttribute("data-target-modal");
      if (!modalId) return;
      const modal = document.getElementById(modalId);
      if (!modal) return;

      btn.addEventListener("click", (e) => {
        e.preventDefault();
        modal.classList.remove("hidden");
      });

      function closeModal() {
        modal?.classList.add("hidden");
      }

      modal.querySelector("[data-media-manager-modal-close]")?.addEventListener("click", closeModal);
      modal.addEventListener("media-manager-close", closeModal);
      modal.addEventListener("media-manager-select", closeModal);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupMediaManagerModals);
  } else {
    setTimeout(setupMediaManagerModals, 100);
  }
</script>
