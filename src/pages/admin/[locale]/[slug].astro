---
/**
 * Rota dinâmica admin/[slug].
 * - Se a URL tiver o parâmetro "domain", carrega o template src/templates/{domain}.astro
 *   (ex.: admin/post?domain=taxonomies&type=category → templates/taxonomies.astro).
 * - Caso contrário, redireciona: post/page → list; dashboard → admin; settings → settings.
 */
import { locales, defaultLocale } from "../../../i18n/index.ts";
import { db } from "../../../db/index.ts";
import { getMenuItems } from "../../../lib/menu.ts";
import { ensureTranslationsLoaded } from "../../../lib/i18n-helpers.ts";
import type { MenuItem } from "../../../lib/menu.ts";

const locale = Astro.params["locale"] ?? defaultLocale;
const slug = Astro.params["slug"];
const domain = Astro.url.searchParams.get("domain");
const type = Astro.url.searchParams.get("type") ?? "";

if (!locales.includes(locale as "en" | "es" | "pt-br")) {
  return Astro.redirect(`/admin/${defaultLocale}`);
}
if (!slug) return Astro.redirect(`/admin/${locale}`);

// Pré-carregar traduções
await ensureTranslationsLoaded(locale);

/** Import dinâmico: import estático de .astro falha no dependency scan do esbuild (só vê o frontmatter, sem default export). */
let TemplateComponent: Awaited<
  typeof import("../../../templates/taxonomies.astro")
>["default"] | null = null;
if (domain === "taxonomies") {
  TemplateComponent = (await import("../../../templates/taxonomies.astro"))
    .default;
}

let menuItems: MenuItem[] = [];
let params: Record<string, string> = {};
let user: { email?: string; name?: string; image?: string | null } | null = null;

if (TemplateComponent) {
  // @ts-expect-error - Astro.locals.user está definido em env.d.ts
  user = Astro.locals.user;
  if (!user) {
    return new Response("Unauthorized", { status: 401 });
  }
  const { getRoleFromUser, canAccessRoute, filterMenuItemsByRole } = await import("../../../lib/permissions.ts");
  const roleId = getRoleFromUser(user);
  const pathname = Astro.url.pathname;
  const allowed = await canAccessRoute(db, roleId, pathname);
  if (!allowed) {
    return new Response("Forbidden", { status: 403 });
  }
  const allMenuItems = await getMenuItems(db);
  menuItems = await filterMenuItemsByRole(db, allMenuItems, roleId);
  Astro.url.searchParams.forEach((value, key) => {
    params[key] = value;
  });
} else {
  if (slug === "post" || slug === "page") {
    return Astro.redirect(`/admin/${locale}/list?type=${slug}&limit=10&page=1`);
  }
  if (slug === "dashboard") {
    return Astro.redirect(`/admin/${locale}`);
  }
  if (slug === "settings") {
    return Astro.redirect(`/admin/${locale}/settings?page=general`);
  }
  return Astro.redirect(`/admin/${locale}`);
}
---

{
  TemplateComponent && domain && (
    <TemplateComponent
      locale={locale}
      slug={slug}
      domain={domain}
      type={type}
      menuItems={menuItems}
      params={params}
      user={user}
    />
  )
}

