---
/** @see https://docs.astro.build/en/reference/configuration-reference/#output */
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import ContentEditor from "../../../components/ContentEditor.astro";
import UserTemplate from "../../../templates/user.astro";
import AttachmentTemplate from "../../../templates/attachment.astro";
import TranslationsTemplate from "../../../templates/translations_languages.astro";
import SettingsTemplate from "../../../templates/settings.astro";
import ThemesTemplate from "../../../templates/themes.astro";
import { db } from "../../../db/index.ts";
import { getRecordById } from "../../../lib/content-source.ts";
import TaxonomyAddModal from "../../../components/TaxonomyAddModal.astro";
import CustomFieldsWrapper from "../../../components/CustomFieldsWrapper.astro";
import ContentEditorSidebar from "../../../components/ContentEditorSidebar.astro";
import ContentFormNotification from "../../../components/ContentFormNotification.astro";
import { getMenuItems } from "../../../lib/menu.ts";
import { t, locales, defaultLocale } from "../../../i18n/index.ts";
import { ensureTranslationsLoaded } from "../../../lib/i18n-helpers.ts";
import {
  getContentPageData,
  isContentPageRedirect,
} from "../../../lib/services/content-page-data.ts";
import "../../../styles/content-editor.css";


const locale = Astro.params["locale"] ?? defaultLocale;
if (!locales.includes(locale as "en" | "es" | "pt-br")) {
  return Astro.redirect(`/admin/${defaultLocale}`);
}

// Pré-carregar traduções
await ensureTranslationsLoaded(locale);

const user = Astro.locals.user;
if (!user) {
  return new Response("Unauthorized", { status: 401 });
}
const layoutUser = {
  email: user.email,
  name: user.name,
  image: user.image ?? null,
};

const { getRoleFromUser, canAccessRoute, filterMenuItemsByRole, isAuthorRole } = await import("../../../lib/permissions.ts");
const roleId = getRoleFromUser(user);
const pathname = Astro.url.pathname;
const allowed = await canAccessRoute(db, roleId, pathname);
if (!allowed) {
  return new Response("Forbidden", { status: 403 });
}

const allMenuItems = await getMenuItems(db);
const menuItems = await filterMenuItemsByRole(db, allMenuItems, roleId);
const postTypesWithNew = menuItems
  .filter((item) => item.menuOptions.includes("new"))
  .map((item) => item.postTypeSlug);

const postTypeSlug = Astro.url.searchParams.get("post_type") ?? "";
const action = Astro.url.searchParams.get("action") ?? "";
const idParam = Astro.url.searchParams.get("id");

const validAction = action === "new" || action === "edit";
const allowedType = postTypeSlug && postTypesWithNew.includes(postTypeSlug);

if (!allowedType || !validAction) {
  return Astro.redirect(`/admin/${locale}/list?type=post&limit=10&page=1`);
}

const isUserType = postTypeSlug === "user";
const isValidEditId = isUserType
  ? (id: string | null) => Boolean(id && id.trim().length > 0)
  : (id: string | null) => Boolean(id && /^\d+$/.test(id));

if (action === "edit" && (!idParam || !isValidEditId(idParam))) {
  return Astro.redirect(
    `/admin/${locale}/list?type=${postTypeSlug}&limit=10&page=1`
  );
}

const showUserTemplate = postTypeSlug === "user";
const showAttachmentTemplate = postTypeSlug === "attachment";
const showTranslationsTemplate = postTypeSlug === "translations_languages";
const showSettingsTemplate = postTypeSlug === "settings";
const showThemesTemplate = postTypeSlug === "themes";

/** Registro da configuração para SettingsTemplate (edit). */
let settingsRecord: { id: number; name: string; value: string; autoload: boolean } | null = null;
if (showSettingsTemplate && action === "edit" && idParam) {
  const res = await getRecordById(db, "settings", idParam);
  if (res.kind === "table" && res.record) {
    const r = res.record;
    settingsRecord = {
      id: Number(r["id"]),
      name: String(r["name"] ?? ""),
      value: String(r["value"] ?? ""),
      autoload: Boolean(r["autoload"]),
    };
  }
}

let taxonomyBlocks: { id: number; name: string; slug: string; type: string; children: { id: number; name: string; slug: string }[] }[] = [];
let selectedTermIds: number[] = [];
let users: { id: string; name: string }[] = [];
let post: {
  id: number;
  title: string;
  slug: string;
  excerpt: string | null;
  body: string | null;
  status: string | null;
  author_id: string | null;
  id_locale_code: number | null;
  meta_values: string | null;
} | null = null;
let pageTitle = "";
let initialTitle = "";
let initialSlug = "";
let initialExcerpt = "";
let initialStatus = "draft";
let initialAuthorId = "";
let initialOrder = "";
let initialLocaleId: number | null = null;
let asideAccordionName = "content-aside";
let thumbnailPath = "";
let thumbnailUrl = "";
let thumbnailAttachmentId: number | null = null;
let hasPostThumbnail = false;
let hasCustomFields = false;
let initialCustomFields: Array<{ id: number; title: string; rows: Array<{ id: number; name: string; value: string; type?: string }> }> = [];
let templateCustomFieldsList: Array<{ id: number; title: string; meta_values: string | null }> = [];

if (!showUserTemplate && !showAttachmentTemplate && !showTranslationsTemplate && !showSettingsTemplate) {
  const result = await getContentPageData({
    db,
    locale,
    postTypeSlug,
    action,
    idParam,
    userId: user?.id ?? "",
    authorIdRestrict: isAuthorRole(roleId) && user?.id ? user.id : null,
  });
  if (isContentPageRedirect(result)) {
    return Astro.redirect(result.url);
  }
  taxonomyBlocks = result.taxonomyBlocks;
  selectedTermIds = result.selectedTermIds;
  users = result.users;
  post = result.post;
  pageTitle = result.pageTitle;
  initialTitle = result.initialTitle;
  initialSlug = result.initialSlug;
  initialExcerpt = result.initialExcerpt;
  initialStatus = result.initialStatus;
  initialAuthorId = result.initialAuthorId;
  initialOrder = result.initialOrder;
  initialLocaleId = result.initialLocaleId;
  asideAccordionName = result.asideAccordionName;
  thumbnailPath = result.thumbnailPath;
  thumbnailUrl = result.thumbnailUrl;
  thumbnailAttachmentId = result.thumbnailAttachmentId;
  hasPostThumbnail = result.hasPostThumbnail;
  hasCustomFields = result.hasCustomFields;
  initialCustomFields = result.initialCustomFields;
  templateCustomFieldsList = result.templateCustomFieldsList;
}

const initialThumbnailAttachmentId =
  thumbnailAttachmentId !== null && thumbnailAttachmentId !== undefined
    ? Number(thumbnailAttachmentId)
    : 0;

const templateProps = {
  locale,
  postTypeSlug,
  action,
  idParam,
  menuItems,
  currentUser: user,
};
const showAlternateTemplate =
  showUserTemplate ||
  showAttachmentTemplate ||
  showTranslationsTemplate ||
  showSettingsTemplate ||
  showThemesTemplate;
---
{showUserTemplate && <UserTemplate {...templateProps} />}
{showAttachmentTemplate && <AttachmentTemplate {...templateProps} />}
{showTranslationsTemplate && <TranslationsTemplate {...templateProps} />}
{showSettingsTemplate && (
  <SettingsTemplate {...templateProps} record={settingsRecord} />
)}
{showThemesTemplate && <ThemesTemplate {...templateProps} />}
{!showAlternateTemplate && (
<AdminLayout title={pageTitle} locale={locale} menuItems={menuItems} user={layoutUser}>
  <!-- Dados iniciais para o form (script sem import para não quebrar como módulo) -->
  <script
    define:vars={{
      initialTitle: String(initialTitle || ""),
      initialSlug: String(initialSlug || ""),
      initialExcerpt: String(initialExcerpt || ""),
      initialStatus: String(initialStatus || "draft"),
      initialAuthorId: String(initialAuthorId || ""),
      initialOrder: String(initialOrder || ""),
      thumbnailPath: String(thumbnailPath || ""),
      thumbnailUrl: String(thumbnailUrl || ""),
      initialThumbnailAttachmentId: initialThumbnailAttachmentId !== null && initialThumbnailAttachmentId !== undefined ? Number(initialThumbnailAttachmentId) : 0,
    }}
  >
    window.__contentFormProps = {
      initialTitle,
      initialSlug,
      initialExcerpt,
      initialStatus,
      initialAuthorId,
      initialOrder,
      thumbnailPath,
      thumbnailUrl,
      initialThumbnailAttachmentId,
    };
  </script>
  <script>
    import "../../../scripts/content-form-init.ts";
  </script>

  <div class="h-full flex flex-col min-h-0 py-6 pl-6 pr-0">
    <form
      method="post"
      action="/api/posts"
      class="flex flex-col gap-4 w-full min-h-0 flex-1"
      data-is-edit={String(action === "edit")}
      x-data="contentForm"
      x-init="if ($el.dataset.isEdit !== 'true') slug = (window.slugify && window.slugify(title)) || ''"
      @blocknote-excerpt.window="excerpt = ($event.detail.text || '').slice(0, 250)"
    >
      <ContentFormNotification />

      <div id="content-form-error" class="mr-6 min-h-[1.5rem]" aria-live="polite"></div>

      <div class="flex gap-6 w-full min-h-0 flex-1">
      <input type="hidden" name="post_type" value={postTypeSlug} />
      <input type="hidden" name="action" value={action} />
      {
        action === "edit" && post && (
          <input type="hidden" name="id" value={post.id} />
        )
      }
      <input type="hidden" name="locale" value={locale} />

      <div class="flex-1 min-w-0 flex flex-col gap-4 min-h-0">
        <div class="form-control shrink-0">
          <label for="title" class="label">
            <span class="label-text">{t(locale, "admin.list.titleColumn")}</span
            >
          </label>
          <input
            type="text"
            id="title"
            name="title"
            required
            class="input input-bordered w-full"
            value={initialTitle}
            x-model="title"
            @input="slug = (window.slugify && window.slugify(title)) || ''"
          />
        </div>

        <div class="form-control flex-1 min-h-0 flex flex-col shrink-0">
          <div class="flex-1 min-h-0 content-editor-fullheight">
            <ContentEditor
              initialBody={post?.body ?? ""}
              name="body"
              inputId="body"
              locale={locale}
            />
          </div>
        </div>

        {hasCustomFields && (
          <div id="custom-fields-wrapper-root" class="mt-4">
            <CustomFieldsWrapper
              initialData={action === "edit" ? initialCustomFields : []}
              templateCustomFields={templateCustomFieldsList}
            />
          </div>
        )}
      </div>

      <ContentEditorSidebar
        locale={locale}
        asideAccordionName={asideAccordionName}
        action={action}
        users={users}
        initialLocaleId={initialLocaleId}
        initialSlug={initialSlug}
        initialExcerpt={initialExcerpt}
        initialOrder={initialOrder}
        hasPostThumbnail={hasPostThumbnail}
        thumbnailUrl={thumbnailUrl}
        taxonomyBlocks={taxonomyBlocks}
        selectedTermIds={selectedTermIds}
      />
      </div>
    </form>
    <!-- Modal fora do form principal para evitar form aninhado (HTML inválido) -->
    <TaxonomyAddModal locale={locale} />
  </div>
</AdminLayout>
)}

