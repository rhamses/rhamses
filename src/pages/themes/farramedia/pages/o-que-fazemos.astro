---
import Layout from "../layouts/default.astro";
import Pagebanner from "../partials/pagebanner.astro";
import { getLanguageFromUrl } from "../i18n/utils";
import { GetPage } from "../helpers/helpers";

const lang = getLanguageFromUrl(Astro.url);
const oQueFazemos = await GetPage(lang, "oquefazemos");
let { page } = Astro.props;
if (!page) {
  page = "o-que-fazemos";
}
---

<style lang="scss" is:global>
  // O que Fazemos
  .o-que-fazemos {
    .section--wrapper2 {
      @media screen and (min-width: 0) {
        margin-top: -15vw;
      }
      @media screen and (min-width: 700px) {
        margin-top: -220px;
      }
      @media screen and (min-width: 1025px) {
        margin-top: -150px;
      }
    }
  }
  .what-we-do {
    .section--wrapper2 {
      @media screen and (min-width: 0) {
        margin-top: -220px;
      }
      @media screen and (min-width: 1024px) {
        margin-top: -190px;
      }
    }
    .pagebanner--image {
      display: none;
    }
  }
  ////////////////////////////////
  .section--wrapper2 {
    padding-bottom: 2rem;
    position: relative;

    color: #fff;
    text-align: center;

    @media screen and (min-width: 0) {
      // margin-top: -10rem;
    }

    @media screen and (min-width: 1024px) {
      // margin-top: -20rem;
    }

    h3 {
      @media screen and (min-width: 0) {
        margin: 0 auto;
        max-width: 800px;

        color: #fff;
        &#tit1 {
          margin-bottom: 5.5rem;
        }
      }
      @media screen and (min-width: 600px) {
        font-size: 50px;
      }
    }

    ul {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-left: auto;
      margin-right: auto;
      max-width: 1000px;
      list-style-type: none;
      flex-wrap: wrap;
      flex: 1 1 auto;

      li {
        @media screen and (min-width: 0) {
          margin-bottom: 6rem;
          flex-basis: 50%;
        }
        @media screen and (min-width: 600px) {
          flex-basis: 25%;
        }
        &.tv::before {
          background-image: url("/servicos/televisao.png");
        }
        &.ent::before {
          background-image: url("/servicos/filme.png");
        }
        &.pub::before {
          background-image: url("/servicos/publicidade.png");
        }
        &.pod::before {
          background-image: url("/servicos/podcast.png");
        }
        &.cin::before {
          background-image: url("/servicos/cinema.png");
        }
        &.soc::before {
          background-image: url("/servicos/midia-social.png");
        }
        &.liv::before {
          background-image: url("/servicos/instagram-ao-vivo.png");
        }
        &.corp::before {
          background-image: url("/servicos/corporativo.png");
        }
        span {
          display: inline-block;
          line-height: 1;
          max-width: 200px;

          font-weight: bold;
          text-transform: uppercase;
        }
      }
    }

    .intro {
      @media screen and (min-width: 0) {
        max-width: 800px;
        margin: 1rem auto 4rem;
      }
      @media screen and (max-width: 1023px) {
        padding-left: 1rem;
        padding-right: 1rem;
      }
    }

    .service--wrapper {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-around;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 4rem;
    }

    .service--item {
      @media screen and (max-width: 500px) {
        width: 100%;
      }
      @media screen and (min-width: 0) {
        box-sizing: border-box;
        display: flex;
        align-items: center;
        margin: 1rem;
        padding: 2rem;

        border: solid 1px #fff;
        border-radius: 50px;
      }
      @media screen and (max-width: 1024px) {
        flex-wrap: wrap;
        br {
          display: none;
        }
      }
      @media screen and (min-width: 1025px) {
        margin: 2em 0;
        justify-content: space-between;
        height: 250px;
      }
      @media screen and (min-width: 1500px) {
        max-width: 800px;
        width: 50%;
        &.producao {
          h2 {
            max-width: 87px;
          }
        }
        &.roteiro {
          h2 {
            width: 223px;
          }
        }
        &.estrategia {
          h2 {
            max-width: 150px;
          }
          p {
            max-width: 350px;
          }
        }
        &.posproducao {
          p {
            max-width: 360px;
          }
        }
        &.social {
          h2 {
            max-width: 240px;
          }
          p {
            max-width: 315px;
          }
        }
        &.artistico {
          h2 {
            max-width: 290px;
          }
        }
      }

      h2 {
        color: #fff;
        text-align: left;
        width: 100%;
        @media screen and (max-width: 1024px) {
          text-align: center;
        }
        @media screen and (min-width: 0) {
          font-size: 1.5rem;
        }
        @media screen and (min-width: 1025px) {
          font-size: 2rem;
          max-width: 255px;
        }
      }
      p {
        @media screen and (min-width: 0) {
          letter-spacing: 1px;
        }
        @media screen and (min-width: 1025px) {
          width: 450px;

          text-align: right;
        }
      }
    }
  }
  .servicos--wrapper {
    background-image: url("/optimized/static-bg.webp");
  }
  .edgtf-st-title {
    margin-bottom: 20px;

    text-align: center;
  }
  .logoCats {
    display: block;
    margin: 0 auto 1rem;
  }
</style>
<Layout page={page}>
  <Pagebanner
    pagename={oQueFazemos.title}
    deskimage={oQueFazemos.image}
    mobimage={oQueFazemos.images[0]}
  />
</Layout>
