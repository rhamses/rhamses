---
import Page from "../../partials/portfolio-inner.astro";
import { createEdgepressContent } from "../../utils/api";

const content = createEdgepressContent(Astro.locals, {
  baseUrl: Astro.url.origin,
});

const slug = Astro.props.slug ?? Astro.params.slug;
const page = "trabalhos";

if (!slug) {
  return Astro.redirect("/trabalhos");
}

type CustomFieldGroup = {
  slug: string;
  fields?: { name: string; value: string }[];
};

let post: {
  id?: number;
  title: string;
  body: string;
  images?: { name: string; value: string }[];
  videos?: { name: string; value: string }[];
  fichaTecnica?: { name: string; value: string }[];
  categories?: string;
} = {
  title: "",
  body: "",
  categories: "",
};

try {
  const data = (await content.getBySlug(slug)) as {
    id?: number;
    title?: string;
    body?: string;
    body_smart?: string;
    meta_values?: Record<string, unknown>;
    custom_fields?: CustomFieldGroup[];
    taxonomies?: { name: string }[];
    media?: unknown;
  };

  const rawCustomFields = Array.isArray(data.custom_fields)
    ? data.custom_fields
    : [];

  const rawImages = rawCustomFields.find((item) =>
    item.slug.includes("jobs-imagens"),
  );
  const rawVideos = rawCustomFields.find((item) =>
    item.slug.includes("job-videos"),
  );
  const rawFicha = rawCustomFields.find((item) =>
    item.slug.includes("ficha-tecnica"),
  );

  const rawTaxonomies =
    Array.isArray(data.taxonomies) && data.taxonomies.length > 0
      ? data.taxonomies.map((item) => item.name).join(", ")
      : "";

  post = {
    id: data.id,
    title: data.title ?? "",
    body:
      typeof data.body_smart === "string"
        ? data.body_smart
        : (data.body as string) ?? "",
    images: Array.isArray(rawImages?.fields)
      ? (rawImages.fields as { name: string; value: string }[])
      : undefined,
    videos: Array.isArray(rawVideos?.fields)
      ? (rawVideos.fields as { name: string; value: string }[])
      : undefined,
    fichaTecnica: Array.isArray(rawFicha?.fields)
      ? (rawFicha.fields as { name: string; value: string }[])
      : undefined,
    categories: rawTaxonomies,
  };
} catch (error) {
  return Astro.redirect("/trabalhos");
}
---

<Page page={page} post={post} />
