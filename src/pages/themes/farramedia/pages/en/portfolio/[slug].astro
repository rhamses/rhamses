---
import Page from "../../../partials/portfolio-inner.astro";
import {
  GetCategoriesPost,
  GetCategories,
  GetPosts,
  TagsFormat,
} from "../../../helpers/helpers";
import { getLanguageFromUrl } from "../../../i18n/utils";
const slug = Astro.props.slug ?? Astro.params.slug;
const page = "trabalhos";
const lang = getLanguageFromUrl(Astro.url);
const posts = await GetPosts({ "filters[slug][$eq]": slug });
let post = posts
  .map((post: any) => TagsFormat(post))
  .filter((post: any) => post.language.includes(lang));
if (post.length > 0) {
  post = post[0];
  const postCategories = await GetCategoriesPost({
    "filters[postId][$eq]": post.id,
  });
  const categories = await Promise.all(
    postCategories.map(async (cat: any) => await GetCategories(cat.categoryId))
  );
  post.categories = categories;
}
---

<Page page={page} post={post} />
