---
import Page from "../../trabalhos/index.astro";
import { getCollection } from "astro:content";
export async function getStaticPaths() {
  const jobs = await getCollection("portfolioen");
  return jobs.map((job) => ({
    params: { slug: job.id.replace(".md", "") },
    props: { post: job, page: "jobs" },
  }));
}
---

<Page page="jobs jobs-en" />
