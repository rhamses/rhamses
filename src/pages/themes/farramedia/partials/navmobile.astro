---
import Link from "../components/navItem.astro";
import Submenu from "../components/submenu.astro";
import { getLanguageFromUrl, useTranslations } from "../i18n/utils";
const lang = getLanguageFromUrl(Astro.url);
const t = useTranslations(lang);
const url = Astro.url;
const isActive = (menu: string) => {
  if (url.pathname === menu) {
    return true;
  }
  return false;
};
---

<script type="module" is:inline>
  // document.querySelectorAll(".edgtf-mobile-nav .menu-item a").forEach((item) =>
  //   item.addEventListener("click", (e) => {
  //     if (e.target.innerHTML.includes("Trabalhos")) {
  //       e.preventDefault();
  //       e.target.nextElementSibling.classList.toggle("hide");
  //     }
  //   })
  // );
  document.querySelectorAll(".has-submenu").forEach((el) => {
    el.children[0].addEventListener("click", (e) => {
      e.preventDefault();
      el.children[1].classList.toggle("hide");
    });
  });
</script>

<nav class="edgtf-mobile-nav">
  <div class="edgtf-grid">
    <ul id="menu-farra-mob-pt" class="">
      <Link label={t("navHome")} url={t("pagesHome")} active={isActive("/")} />
      <Link
        label={t("navDiretor")}
        url={t("pagesDiretor")}
        active={isActive("/")}
        classList="has-submenu"
      >
        <Submenu id="submenu" posttype="diretores" />
      </Link>
      <Link
        label={t("navJob")}
        url={t("pagesJob")}
        active={isActive("/trabalhos")}
        classList="has-submenu"
      >
        <Submenu id="submenu" posttype="jobs" />
      </Link>
      <Link
        label={t("navAbout")}
        url={t("pagesAbout")}
        active={isActive("/quem-somos")}
      />
      <Link
        label={t("navWhatwedo")}
        url={t("pagesWhatwedo")}
        active={isActive("/o-que-fazemos")}
      />
      <Link
        label={t("navContact")}
        url={t("pagesContact")}
        active={isActive("/contato")}
      />
      <Link
        url="/en"
        label="English version"
        flag="data:image/png;base64,"
      />
      <Link url="/" label="Versão em Portguês" flag="/brasil.svg" />
    </ul>
  </div>
</nav>
