---
interface Props {
  label?: any;
  url: any;
  active?: boolean;
  flag?: string;
  classList?: string;
}
const { label, url, active, flag, classList } = Astro.props;
let css =
  "menu-item menu-item-type-post_type menu-item-object-page menu-item-home page_item page-item-3708 narrow";
if (active) {
  css = css + " edgtf-active-item";
}
if (classList) {
  css = css + " " + classList;
}
---

<style lang="scss">
  .has-submenu {
    position: relative;
    & > a {
      &::before {
        content: "";
        position: absolute;
        right: 10px;
        margin-top: 2px;
        height: 20px;
        width: 20px;

        background-image: url("data:image/svg+xml;base64,");
        background-repeat: no-repeat;
        transform: rotate(0);
        transition: all 0.5s ease-in-out;
      }
      &.active::before {
        transform: rotate(180deg);
      }
    }
  }
</style>

<style is:global lang="scss">
  .home-en,
  .what-we-do,
  .who-we-are,
  .trabalhos,
  .diretores,
  .jobs-en {
    .edgtf-main-menu {
      .submenu {
        ul {
          // overflow-x: scroll;
          li {
            max-width: 150px;
            a {
              // outline: solid 2px red;
              display: flex;
              align-items: center;
              justify-content: center;
              height: 100%;
              min-height: 32px;
              line-height: 1.5;
            }
          }
        }
      }
    }
  }
</style>

<li class={css}>
  <a href={url}>
    <span class="item_outer">
      <span class="item_text">
        {
          flag ? (
            <img
              src={flag}
              alt="English version"
              width="16"
              height="11"
              style="width: 16px; height: 11px;"
            />
          ) : (
            ""
          )
        }
        {label ? label : ""}
      </span>
    </span>
  </a>
  <slot id="submenu" />
</li>
