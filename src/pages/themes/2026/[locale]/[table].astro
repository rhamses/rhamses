---
import Theme2026Layout from "../../../../layouts/Theme2026Layout.astro";

const localeParam = Astro.params["locale"];
const tableParam = Astro.params["table"];

const locale = typeof localeParam === "string" && localeParam.length > 0 ? localeParam : "pt-br";
const table = typeof tableParam === "string" && tableParam.length > 0 ? tableParam : "";

if (!table) {
  return Astro.redirect(`/themes/2026/${locale}`);
}

const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") ?? "1", 10) || 1);
const limit = Math.min(100, Math.max(1, parseInt(Astro.url.searchParams.get("limit") ?? "10", 10) || 10));
const order = Astro.url.searchParams.get("order") ?? "id";
const orderDir = (Astro.url.searchParams.get("orderDir") === "asc" ? "asc" : "desc") as "asc" | "desc";

const apiUrl = new URL(`/api/content/${encodeURIComponent(table)}`, Astro.url.origin);
apiUrl.searchParams.set("page", String(page));
apiUrl.searchParams.set("limit", String(limit));
apiUrl.searchParams.set("order", order);
apiUrl.searchParams.set("orderDir", orderDir);

// Para posts, permitir filtrar por locale
if (table === "posts") {
  apiUrl.searchParams.set("locale", locale);
}

type ListResult = {
  items: Record<string, unknown>[];
  total: number;
  page: number;
  limit: number;
  totalPages: number;
  columns: string[];
};

let result: ListResult = { items: [], total: 0, page: 1, limit, totalPages: 0, columns: [] };
try {
  const res = await fetch(apiUrl.toString());
  if (res.ok) {
    result = await res.json();
  }
} catch {
  result = { items: [], total: 0, page: 1, limit, totalPages: 0, columns: [] };
}

const { items, total, totalPages, columns } = result;
const isHtmx = Astro.request.headers.get("HX-Request") === "true";

function formatDate(ts: unknown): string {
  if (ts == null) return "—";
  const n = typeof ts === "number" ? ts : parseInt(String(ts), 10);
  if (Number.isNaN(n)) return "—";
  return new Date(n).toLocaleDateString("pt-BR", { dateStyle: "short" });
}

function buildPageUrl(p: number): string {
  const u = new URL(Astro.url.pathname, Astro.url.origin);
  u.searchParams.set("page", String(p));
  if (limit !== 10) u.searchParams.set("limit", String(limit));
  if (order !== "id") u.searchParams.set("order", order);
  if (orderDir !== "desc") u.searchParams.set("orderDir", orderDir);
  return u.pathname + u.search;
}

function getTitle(row: Record<string, unknown>): string {
  if ("title" in row && row["title"] != null) return String(row["title"]);
  if ("name" in row && row["name"] != null) return String(row["name"]);
  if ("slug" in row && row["slug"] != null) return String(row["slug"]);
  if ("id" in row && row["id"] != null) return `#${String(row["id"])}`;
  // fallback: primeira coluna disponível
  const col = columns[0];
  return col && row[col] != null ? String(row[col]) : "Registro";
}

function getExcerpt(row: Record<string, unknown>): string | null {
  if ("excerpt" in row && row["excerpt"] != null) return String(row["excerpt"]);
  if ("description" in row && row["description"] != null) return String(row["description"]);
  if ("body" in row && row["body"] != null) {
    const text = String(row["body"]);
    return text.length > 160 ? `${text.slice(0, 157)}…` : text;
  }
  // tentar primeira coluna de texto longa
  for (const col of columns) {
    const value = row[col];
    if (typeof value === "string" && value.length > 0) {
      return value.length > 160 ? `${value.slice(0, 157)}…` : value;
    }
  }
  return null;
}

function getDate(row: Record<string, unknown>): string | null {
  if ("published_at" in row && row["published_at"] != null) return formatDate(row["published_at"]);
  if ("created_at" in row && row["created_at"] != null) return formatDate(row["created_at"]);
  if ("updated_at" in row && row["updated_at"] != null) return formatDate(row["updated_at"]);
  return null;
}

function getId(row: Record<string, unknown>): string | null {
  if ("id" in row && row["id"] != null) return String(row["id"]);
  return null;
}
---

{isHtmx ? (
  <div class="space-y-6">
    <div id="table-list">
      {items.length === 0 ? (
        <p class="text-base-content/70 py-8">Nenhum registro encontrado.</p>
      ) : (
        <ul class="space-y-4">
          {items.map((row) => {
            const id = getId(row);
            return (
              <li class="card bg-base-100 shadow border border-base-300">
                <div class="card-body">
                  <h2 class="card-title text-lg break-all">
                    {id ? (
                      <a
                        href={`/themes/2026/${locale}/${table}/${id}`}
                        class="link link-hover"
                      >
                        {getTitle(row)}
                      </a>
                    ) : (
                      getTitle(row)
                    )}
                  </h2>
                  {(() => {
                    const excerpt = getExcerpt(row);
                    return excerpt ? (
                      <p class="text-base-content/70 text-sm line-clamp-2 wrap-break-word">
                        {excerpt}
                      </p>
                    ) : null;
                  })()}
                  {(() => {
                    const date = getDate(row);
                    return date ? (
                      <p class="text-xs text-base-content/50">{date}</p>
                    ) : null;
                  })()}
                </div>
              </li>
            );
          })}
        </ul>
      )}
    </div>
    {totalPages > 1 && (
      <div id="table-pagination" class="flex flex-wrap gap-2 justify-center items-center">
        {page > 1 && (
          <a
            href={buildPageUrl(page - 1)}
            class="btn btn-sm btn-ghost"
            hx-get={buildPageUrl(page - 1)}
            hx-target="#table-container"
            hx-swap="innerHTML"
            hx-push-url="true"
          >
            Anterior
          </a>
        )}
        <span class="text-sm text-base-content/70 px-2">
          Página {page} de {totalPages} ({total} itens)
        </span>
        {page < totalPages && (
          <a
            href={buildPageUrl(page + 1)}
            class="btn btn-sm btn-ghost"
            hx-get={buildPageUrl(page + 1)}
            hx-target="#table-container"
            hx-swap="innerHTML"
            hx-push-url="true"
          >
            Próxima
          </a>
        )}
      </div>
    )}
  </div>
) : (
  <Theme2026Layout title={`Tabela ${table} — ${locale.toUpperCase()}`} basePath={`/themes/2026/${locale}`}>
    <div
      class="max-w-3xl mx-auto"
      x-data="{ loading: false }"
      @htmx:beforeRequest.window="loading = true"
      @htmx:afterRequest.window="loading = false"
    >
      <div class="flex items-baseline justify-between gap-2 mb-4">
        <div>
          <a href={`/themes/2026/${locale}`} class="link link-hover text-sm text-base-content/70 mb-1 inline-block">
            ← Todas as tabelas
          </a>
          <h1 class="text-3xl font-bold text-base-content break-all">Tabela {table}</h1>
        </div>
        <span class="text-sm text-base-content/60">
          Página {page} de {totalPages || 1}
        </span>
      </div>

      <div x-show="loading" x-cloak class="flex justify-center py-4">
        <span class="loading loading-spinner loading-md text-primary"></span>
      </div>

      <div id="table-container" class="space-y-6">
        <div id="table-list">
          {items.length === 0 ? (
            <p class="text-base-content/70 py-8">Nenhum registro encontrado.</p>
          ) : (
            <ul class="space-y-4">
              {items.map((row) => {
                const id = getId(row);
                return (
                  <li class="card bg-base-100 shadow border border-base-300">
                    <div class="card-body">
                      <h2 class="card-title text-lg break-all">
                        {id ? (
                          <a
                            href={`/themes/2026/${locale}/${table}/${id}`}
                            class="link link-hover"
                          >
                            {getTitle(row)}
                          </a>
                        ) : (
                          getTitle(row)
                        )}
                      </h2>
                      {(() => {
                        const excerpt = getExcerpt(row);
                        return excerpt ? (
                          <p class="text-base-content/70 text-sm line-clamp-2 wrap-break-word">
                            {excerpt}
                          </p>
                        ) : null;
                      })()}
                      {(() => {
                        const date = getDate(row);
                        return date ? (
                          <p class="text-xs text-base-content/50">{date}</p>
                        ) : null;
                      })()}
                    </div>
                  </li>
                );
              })}
            </ul>
          )}
        </div>

        {totalPages > 1 && (
          <div id="table-pagination" class="flex flex-wrap gap-2 justify-center items-center">
            {page > 1 && (
              <a
                href={buildPageUrl(page - 1)}
                class="btn btn-sm btn-ghost"
                hx-get={buildPageUrl(page - 1)}
                hx-target="#table-container"
                hx-swap="innerHTML"
                hx-push-url="true"
              >
                Anterior
              </a>
            )}
            <span class="text-sm text-base-content/70 px-2">
              Página {page} de {totalPages} ({total} itens)
            </span>
            {page < totalPages && (
              <a
                href={buildPageUrl(page + 1)}
                class="btn btn-sm btn-ghost"
                hx-get={buildPageUrl(page + 1)}
                hx-target="#table-container"
                hx-swap="innerHTML"
                hx-push-url="true"
              >
                Próxima
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </Theme2026Layout>
)}

<style is:global>
  [x-cloak] { display: none !important; }
</style>

