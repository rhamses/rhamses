---
import BaseHead from "../../../../components/themes/baseHead.astro";
import Header from "../parts/header.astro";
import BaseBody from "../../../../components/themes/baseBody.astro";
import PostList from "../../../../components/themes/postList.astro";
import "../../../../assets/app.css";
import "../theme.css";

const locale = String(Astro.params["locale"] ?? "").trim();
const htmlLang = locale.startsWith("pt")
  ? "pt-BR"
  : locale.startsWith("es")
    ? "es"
    : "en";
const currentThemePath = locale ? `/${locale}` : "/";
---

<!doctype html>
<html lang={htmlLang}>
  <BaseHead pageKey="hello-world" locale={locale} />
  <body class="bg-white font-sans text-slate-900 antialiased">
    <Header locale={locale} currentThemePath={currentThemePath} />
    <main class="mx-auto w-full max-w-5xl px-6 py-12">
      <section class="border-b border-slate-200">
        <BaseBody pageKey="hello-world" locale={locale} />
      </section>

      <!-- <section id="ultimos-posts" class="py-12">
