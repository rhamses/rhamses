<style>
  :global(.starter-nav ul) {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: center;
  }

  :global(.starter-nav a) {
    font-size: 0.95rem;
    font-weight: 500;
    color: rgb(51 65 85);
    transition: color 0.2s ease;
  }

  :global(.starter-nav a:hover) {
    color: rgb(15 23 42);
  }

  :global(.starter-nav li) {
    list-style: none;
  }

  :global(.theme-meta p) {
    margin: 0;
  }
</style>
