---
import { themeContentGateway } from "../../../../core/services/theme-content-gateway.ts";
import "../theme.css";

type ThemePost = {
  id: number;
  slug: string;
  title: string;
  excerpt?: string | null;
  body?: string | null;
  status?: string | null;
  published_at?: number | null;
  created_at?: number | null;
  meta_values?: string | null;
  import_publish_date?: string;
};

const segment = String(Astro.params["locale"] ?? "").trim();
const normalizedSegment = segment.toLowerCase();

const localeMap: Record<string, string> = {
  "pt_br": "pt-BR",
  "pt-br": "pt-BR",
  pt: "pt-BR",
  "en_us": "en",
  "en-us": "en",
  en: "en",
  "es_es": "es",
  "es-es": "es",
  es: "es",
};

const isLocaleSegment = Boolean(localeMap[normalizedSegment]);
const htmlLang = localeMap[normalizedSegment] ?? "pt-BR";

const rows = (await themeContentGateway.getPostsByType("post", {
  limit: "1000",
})) as ThemePost[];

const posts = rows
  .filter((row) => row.status === "published")
  .sort((a, b) => {
    const aTime = Number(a.published_at ?? a.created_at ?? 0);
    const bTime = Number(b.published_at ?? b.created_at ?? 0);
    return bTime - aTime;
  });

const currentPost = isLocaleSegment ? null : posts.find((p) => p.slug === segment);
if (!isLocaleSegment && !currentPost) {
  Astro.response.status = 404;
}

const pageTitle = currentPost ? currentPost.title : "Rhamsés Blog";
const pageDescription = currentPost?.excerpt?.trim()
  ? currentPost.excerpt.trim()
  : "Articles about software engineering and Web development.";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <div class="layout">
      <header class="site-header">
        <a href="/" class="logo">Rhamses</a>
      </header>

      <main class="site-main">
        {
          currentPost ? (
            <div class="container">
              <header class="post-header">
                {
                  currentPost.import_publish_date ? (
                    <p>{currentPost.import_publish_date}</p>
                  ) : null
                }
                <h1>{currentPost.title}</h1>
                <hr />
              </header>
              <article class="post-content" set:html={currentPost.body ?? ""} />
            </div>
          ) : (
            <div class="container">
              <h1>Latest Articles</h1>
              {
                posts.map((post, index) => (
                  <div>
                    {index !== 0 && <hr />}
                    <div class="post-item">
                      <h2>
                        <a href={`/${post.slug}`}>{post.title}</a>
                      </h2>
                      {post.excerpt ? <p>{post.excerpt}</p> : null}
                      <div>
                        {post.import_publish_date ? (
                          <span class="post-item-date">
                            - {post.import_publish_date}
                          </span>
                        ) : null}
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          )
        }
      </main>

      <footer class="site-footer">
        <span>
          &copy; {new Date().getFullYear()} Rhamses Blog. Powered by{" "}
          <a href="https://astro.build" target="_blank" rel="noopener">
            Astro
          </a>
          .
        </span>
      </footer>
    </div>
  </body>
</html>
