---
import Theme2026Layout from "../../../layouts/Theme2026Layout.astro";

export const prerender = false;

let sitePayload: Record<string, unknown> = {};
try {
  const apiUrl = new URL("/api/content/site", Astro.url.origin);
  const res = await fetch(apiUrl.toString());
  if (res.ok) {
    sitePayload = await res.json();
  }
} catch {
  sitePayload = {};
}

const siteName = String(sitePayload["site_name"] ?? "Site 2026");
const siteDescription =
  typeof sitePayload["site_description"] === "string" && sitePayload["site_description"]
    ? sitePayload["site_description"]
    : undefined;
const siteUrl =
  typeof sitePayload["site_url"] === "string" && sitePayload["site_url"]
    ? sitePayload["site_url"]
    : undefined;

const jsonLdRaw = sitePayload["json_ld"];
const jsonLd = Array.isArray(jsonLdRaw) ? (jsonLdRaw as Record<string, unknown>[]) : [];

const seoForLayout: {
  title?: string;
  description?: string;
  canonical?: string;
} = { title: siteName };
if (siteDescription) seoForLayout.description = siteDescription;
if (siteUrl) seoForLayout.canonical = siteUrl;
---

<Theme2026Layout
  title={`${siteName} — Site 2026`}
  basePath="/themes/2026"
  seo={seoForLayout}
  jsonLd={jsonLd}
>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-4xl font-bold text-base-content mb-4">Bem-vindo ao {siteName}</h1>
    <p class="text-lg text-base-content/80 mb-6">
      Este é o tema padrão do repositório de temas. Acesse a listagem de posts para ver o conteúdo do banco de dados.
    </p>
    <a href="/themes/2026/posts" class="btn btn-primary">Ver posts</a>
  </div>
</Theme2026Layout>
