---
import Layout from "../../layouts/default.astro";
import WorkItem from "../../components/workitem.astro";
import { getLanguageFromUrl } from "../../i18n/utils";
import { GetContent, slugify } from "../../helpers/helpers";

const lang = getLanguageFromUrl(Astro.url);
let jobs = await GetContent(lang, "jobs", {});
let { page } = Astro.props;

if (!page) {
  page = "trabalhos";
}
---

<style lang="scss">
  #jobs {
    display: flex;
    flex-wrap: wrap;
    background: #000;
    width: 100%;
  }
</style>
<Layout page={page}>
  <section id="jobs">
    {
      jobs.map((job: any) => (
        <WorkItem
          label={job.title}
          url={`${lang != "br" ? `/${lang}` : ""}/portfolio/${job.slug || slugify(job.title)}`}
          imagepr={job.image}
        />
      ))
    }
  </section>
</Layout>
