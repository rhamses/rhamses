---
import { Image } from "astro:assets";
import Layout from "../layouts/default.astro";
import Pagebanner from "../partials/pagebanner.astro";
import TeamMember from "../components/teamitem.astro";
import { getLanguageFromUrl } from "../i18n/utils";
import {
  GetAboutOQueFazemosItems,
  GetAdminPage,
  GetEquipeOwners,
  getAboutAdminPageSlug,
  memberJobText,
  slugify,
  GetCategoryPosts,
} from "../helpers/helpers";

const lang = getLanguageFromUrl(Astro.url);
const { adminPageSlug: adminPageSlugProp } = Astro.props;
const adminPageSlug = adminPageSlugProp ?? getAboutAdminPageSlug(lang);
const aFarra = await GetAdminPage(lang, adminPageSlug);
const oQueFazemosItems = await GetAboutOQueFazemosItems(lang);
const equipeOwners = await GetEquipeOwners(lang);
const servicosItems = await GetCategoryPosts(lang, "servicos", {
  requireBody: true,
});

const deskImage = aFarra?.thumbnail || aFarra?.thumbnail_url || "";
const mobImage = aFarra?.bg_image || "";
const pageTitle = aFarra?.title ?? "A Farra";

function splitBodyBySeparator(body: string): {
  intro: string;
  afterFounders: string[];
} {
  if (!body?.trim()) return { intro: "", afterFounders: [] };

  const parts = body
    .split(/<hr\b[^>]*\/?>/i)
    .map((part) => part.trim())
    .filter(Boolean);

  if (parts.length <= 1) {
    return { intro: body.trim(), afterFounders: [] };
  }

  return {
    intro: parts[0],
    afterFounders: parts.slice(1),
  };
}

function quemSomosInnerHtml(block: string): string {
  const trimmed = block.replace(/<p>\s*<\/p>/gi, "").trim();
  const singleParagraph = trimmed.match(/^<p[^>]*>([\s\S]*?)<\/p>$/i);
  if (singleParagraph) return singleParagraph[1].trim();
  return trimmed;
}

const { intro: bodyIntro, afterFounders: bodyAfterFounders } = splitBodyBySeparator(
  aFarra?.body ?? "",
);

function parseSocialMedia(value: unknown): string[] | undefined {
  if (Array.isArray(value)) return value as string[];
  if (typeof value === "string" && value.trim()) {
    try {
      const parsed = JSON.parse(value);
      return Array.isArray(parsed) ? parsed : undefined;
    } catch {
      return undefined;
    }
  }
  return undefined;
}

let { page } = Astro.props;
if (!page) {
  page = "quem-somos";
}
---

<style lang="scss">
  .quem-somos-inner {
    @media screen and (min-width: 0) {
      margin: 2.5rem auto 4.5rem;
      color: #fff;
      text-align: center;
    }
    @media screen and (min-width: 1025px) {
      max-width: 782px;
    }
  }
</style>

<Layout page={page}>
  <Pagebanner pagename={pageTitle} deskimage={deskImage} mobimage={mobImage} />
  <div class="o-que-fazemos">
    <section class="section--wrapper2">
      <article>
        {
          bodyIntro ? (
            <div class="quem-somos-inner" set:html={bodyIntro} />
          ) : null
        }
        {
          oQueFazemosItems.length > 0 ? (
            <ul>
              {oQueFazemosItems.map((item: any) => (
                <li>
                  <Image
                    class="logoCats"
                    src={item.image}
                    width={100}
                    height={100}
                    alt=""
                  />
                  <span>{item.title}</span>
                </li>
              ))}
            </ul>
          ) : null
        }
      </article>
    </section>
  </div>
  {
    equipeOwners.length > 0 || bodyAfterFounders.length > 0 ? (
      <div>
        {
          equipeOwners.length > 0 ? (
            <section id="founders" class="edgtf-grid team-members">
              {equipeOwners.map((member: any) => (
                <TeamMember
                  founder={true}
                  socials={parseSocialMedia(member.socialMedia)}
                  imagepr={member.image}
                  name={member.title}
                  job={memberJobText(member)}
                />
              ))}
            </section>
          ) : null
        }
        {
          bodyAfterFounders.map((block) => (
            <div class="edgtf-container-inner">
              <article class="edgtf-grid">
                <div class="edgtf-row-grid-section">
                  <div class="edgtf-grid-col-12">
                    <p class="quem-somos-inner" set:html={quemSomosInnerHtml(block)} />
                  </div>
                </div>
              </article>
            </div>
          ))
        }
      </div>
    ) : null
  }
  {
    servicosItems.length > 0 ? (
      <div>
        <section class="section--wrapper2">
          <article>
            <div class="service--wrapper" style="width: 100%;">
              {servicosItems.map((job: any) => (
                <div class={"service--item " + slugify(job.title)}>
                  <h2 set:html={job.title} />
                  <p>{job.body}</p>
                </div>
              ))}
            </div>
          </article>
        </section>
      </div>
    ) : null
  }
</Layout>

<style lang="scss" is:global>
  .o-que-fazemos {
    .section--wrapper2 {
      @media screen and (min-width: 0) {
        margin-top: -15vw;
      }
      @media screen and (min-width: 700px) {
        margin-top: -220px;
      }
      @media screen and (min-width: 1025px) {
        margin-top: -150px;
      }
    }
  }

  .what-we-do {
    .section--wrapper2 {
      @media screen and (min-width: 0) {
        margin-top: -220px;
      }
      @media screen and (min-width: 1024px) {
        margin-top: -190px;
      }
    }
    .pagebanner--image {
      display: none;
    }
  }

  .section--wrapper2 {
    padding-bottom: 2rem;
    position: relative;
    color: #fff;
    text-align: center;

    h3 {
      @media screen and (min-width: 0) {
        margin: 0 auto;
        max-width: 800px;
        color: #fff;
        &#tit1 {
          margin-bottom: 5.5rem;
        }
      }
      @media screen and (min-width: 600px) {
        font-size: 50px;
      }
    }

    ul {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-left: auto;
      margin-right: auto;
      max-width: 1000px;
      list-style-type: none;
      flex-wrap: wrap;
      flex: 1 1 auto;

      li {
        @media screen and (min-width: 0) {
          margin-bottom: 6rem;
          flex-basis: 50%;
        }
        @media screen and (min-width: 600px) {
          flex-basis: 25%;
        }
        span {
          display: inline-block;
          line-height: 1;
          max-width: 200px;
          font-weight: bold;
          text-transform: uppercase;
        }
      }
    }

    .intro {
      @media screen and (min-width: 0) {
        max-width: 800px;
        margin: 1rem auto 4rem;
      }
      @media screen and (max-width: 1023px) {
        padding-left: 1rem;
        padding-right: 1rem;
      }
    }

    .service--wrapper {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-around;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 4rem;
    }

    .service--item {
      @media screen and (max-width: 500px) {
        width: 100%;
      }
      @media screen and (min-width: 0) {
        box-sizing: border-box;
        display: flex;
        align-items: center;
        margin: 1rem;
        padding: 2rem;
        border: solid 1px #fff;
        border-radius: 50px;
      }
      @media screen and (max-width: 1024px) {
        flex-wrap: wrap;
        br {
          display: none;
        }
      }
      @media screen and (min-width: 1025px) {
        margin: 2em 0;
        justify-content: space-between;
        height: 250px;
      }
      @media screen and (min-width: 1500px) {
        max-width: 800px;
        width: 50%;
        &.producao {
          h2 {
            max-width: 87px;
          }
        }
        &.roteiro {
          h2 {
            width: 223px;
          }
        }
        &.estrategia {
          h2 {
            max-width: 150px;
          }
          p {
            max-width: 350px;
          }
        }
        &.posproducao {
          p {
            max-width: 360px;
          }
        }
        &.social {
          h2 {
            max-width: 240px;
          }
          p {
            max-width: 315px;
          }
        }
        &.artistico {
          h2 {
            max-width: 290px;
          }
        }
      }

      h2 {
        color: #fff;
        text-align: left;
        width: 100%;
        @media screen and (max-width: 1024px) {
          text-align: center;
        }
        @media screen and (min-width: 0) {
          font-size: 1.5rem;
        }
        @media screen and (min-width: 1025px) {
          font-size: 2rem;
          max-width: 255px;
        }
      }
      p {
        @media screen and (min-width: 0) {
          letter-spacing: 1px;
        }
        @media screen and (min-width: 1025px) {
          width: 450px;
          text-align: right;
        }
      }
    }
  }

  .logoCats {
    display: block;
    margin: 0 auto 1rem;
    height: 100px;
    max-width: none;
    width: inherit;
  }

  .team-members {
    display: flex;
    flex-wrap: wrap;
    margin: 0 auto;
    justify-content: space-between;
  }

  @media screen and (max-width: 499px) {
    #founders {
      margin-top: 20px;
    }
  }

  @media screen and (min-width: 1025px) {
    #founders {
      margin-top: -50px;
      z-index: 2;
      position: relative;
    }
  }
</style>
