---
import Page from "../../../partials/portfolio-inner.astro";
import {
  GetPosts,
  TagsFormat,
  getPostCategoriesForDisplay,
  matchesLanguageForPost,
} from "../../../helpers/helpers";
import { themeRouteParam, themeRedirect } from "../../../helpers/route";
import { getLanguageFromUrl } from "../../../i18n/utils";

const slug = themeRouteParam(Astro, "slug");
const page = "trabalhos";
const lang = getLanguageFromUrl(Astro.url);

if (!slug) {
  return themeRedirect("/en/jobs");
}

let posts = await GetPosts({ "filters[slug][$eq]": slug });
posts = posts.filter((p: any) => matchesLanguageForPost(p, lang));
let post = posts[0];
if (post) {
  post = TagsFormat(post);
  post.categories = await getPostCategoriesForDisplay(Number(post.id));
} else {
  return themeRedirect("/en/jobs");
}
---

<Page page={page} post={post} />
