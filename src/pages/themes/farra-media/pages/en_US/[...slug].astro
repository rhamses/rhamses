---
import {
  resolveEnUsRewrite,
  themePagesRewrite,
} from "../../helpers/locale-routes.ts";

const slugParam = Astro.params["slug"];
const segments =
  typeof slugParam === "string" ? slugParam.split("/").filter(Boolean) : [];

const internal = resolveEnUsRewrite(segments);
if (!internal) {
  return new Response("Not found", { status: 404 });
}

return Astro.rewrite(themePagesRewrite(internal));
---
