---
import TeamMember from "../components/teamitem.astro";
import { getLanguageFromUrl } from "../i18n/utils";
import { GetEquipeOwners, memberJobText } from "../helpers/helpers";

const lang = getLanguageFromUrl(Astro.url);
const members = await GetEquipeOwners(lang);

function parseSocialMedia(value: unknown): string[] | undefined {
  if (Array.isArray(value)) return value as string[];
  if (typeof value === "string" && value.trim()) {
    try {
      const parsed = JSON.parse(value);
      return Array.isArray(parsed) ? parsed : undefined;
    } catch {
      return undefined;
    }
  }
  return undefined;
}
---

<style>
  .team-members {
    display: flex;
    flex-wrap: wrap;
    margin: 0 auto;
    justify-content: space-between;
  }
  .edgtf-st-title {
    margin-bottom: 20px;
    margin-top: 20px;
    text-align: center;
  }
  #intro .edgtf-page-subtitle {
    color: #ffffff;
    padding: 0 17%;
    margin-top: 45%;
    font-size: 12px;
    line-height: 1.5em;
    letter-spacing: 0.13em;
    text-transform: none;
  }
  @media screen and (max-width: 499px) {
    #founders {
      margin-top: 20px;
    }
  }
  @media screen and (min-width: 1025px) {
    #founders {
      margin-top: -50px;
      z-index: 2;
      position: relative;
    }
  }
  @media screen and (min-width: 1440px) {
    #founders {
      /* margin-top: -100px; */
    }
  }
</style>
<section id="founders" class="edgtf-grid">
  {
    members.map((member: any) => (
      <TeamMember
        founder={true}
        socials={parseSocialMedia(member.socialMedia)}
        imagepr={member.image}
        name={member.title}
        job={memberJobText(member, { founder: true })}
      />
    ))
  }
</section>
