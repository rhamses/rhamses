---
import linkedin from "../images/icons/linkedin.svg?raw";
import { GetContent } from "../helpers/helpers";
let posts = await GetContent("", "options", {});
posts = posts.filter((item: any) => item.socialMedia);
---

<style lang="scss" is:global>
  .wp-social-link {
    color: #000 !important;
  }
  .trabalhos,
  .jobs {
    .wp-social-link {
      color: #fff !important;
    }
  }
</style>

