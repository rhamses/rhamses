---
import Nav from "../partials/navmobile.astro";
import Logo from "../components/logo.astro";
---

<header class="edgtf-mobile-header">
  <div class="edgtf-mobile-header-inner">
    <div class="edgtf-mobile-header-holder">
      <div class="edgtf-grid">
        <div class="edgtf-vertical-align-containers">
          <div class="edgtf-vertical-align-containers">
            <div class="edgtf-position-left">
              <div class="edgtf-position-left-inner">
                <div class="edgtf-mobile-logo-wrapper">
                  <Logo />
                </div>
              </div>
            </div>
            <div
              class="edgtf-mobile-menu-opener edgtf-mobile-menu-opener-predefined"
            >
              <a class="btn-mob" href="#">
                <span class="edgtf-mobile-menu-icon">
                  <span class="edgtf-hm-lines"
                    ><span class="edgtf-hm-line edgtf-line-1"></span><span
                      class="edgtf-hm-line edgtf-line-2"></span><span
                      class="edgtf-hm-line edgtf-line-3"></span></span
                  >
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <Nav />
  </div>
</header>
