---
export const prerender = false;

const themeSlug = Astro.params["themeSlug"];

if (!themeSlug) {
  return new Response("Theme not found", { status: 404 });
}

/**
 * A home do tema precisa ser servida pela rota real em pages/index.astro
 * para que o Astro injete os <style> dos componentes (import hummingbird + scoped CSS).
 * renderComponent aqui deixava a home sem CSS (~0 blocos <style> vs ~19 nas demais páginas).
 */
return Astro.rewrite(`/themes/${themeSlug}/pages/`);
---
