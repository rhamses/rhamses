---
import Layout from "../../layouts/Layout.astro";
import Notificacao from "../../components/Notificacao.astro";

const sent = Astro.url.searchParams.get("sent") === "1";
const errorParam = Astro.url.searchParams.get("error");
const errorMessages: Record<string, string> = {
  missing_email: "Informe seu email.",
};
const errorMessage = errorParam ? (errorMessages[errorParam] ?? null) : null;
---

<Layout title="Recuperar senha - Edgepress">
  <main class="min-h-screen flex items-center justify-center bg-base-200 p-4">
    <div class="card w-full max-w-md bg-base-100 shadow-xl">
      <div class="card-body">
        <h1 class="card-title justify-center text-2xl mb-4">Recuperar senha</h1>

        {
          sent && (
            <Notificacao
              type="success"
              message="Se esse email estiver cadastrado, você receberá um link para redefinir sua senha. Verifique sua caixa de entrada e spam."
              dismissible
              className="mb-4"
            />
          )
        }
        {
          errorMessage && (
            <Notificacao
              type="error"
              message={errorMessage}
              dismissible
              className="mb-4"
            />
          )
        }

        {
          !sent && (
            <form action="/api/forgot-password" method="post" class="space-y-4">
              <div class="form-control w-full">
                <label class="label" for="email">
                  <span class="label-text">Email</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="seu@email.com"
                  class="input input-bordered w-full"
                  required
                  autocomplete="email"
                />
              </div>
              <div class="form-control mt-6">
                <button type="submit" class="btn btn-primary">
                  Enviar link de recuperação
                </button>
              </div>
            </form>
          )
        }

        <p class="text-center mt-4">
          <a href={`/login`} class="link link-hover label-text-alt">
            Voltar ao login
          </a>
        </p>
      </div>
    </div>
  </main>
</Layout>
