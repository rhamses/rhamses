---
/**
 * Template da página "Cache" em Settings: lista chaves/valores do KV e botão para resetar cache.
 */
import AdminLayout from "../layouts/AdminLayout.astro";
import DataListPanel from "../components/DataListPanel.astro";
import { t, type Locale } from "../i18n/index.ts";
import type { MenuItem } from "../lib/menu.ts";
import {
  buildUrlWithParams,
  filterItemsClientSide,
  parseFilterParams,
} from "../lib/list-utils.ts";

export interface Props {
  locale: string;
  menuItems: MenuItem[];
  currentUser: { email: string; name: string };
  kvItems: { key: string; valuePreview: string }[];
}

const { locale, menuItems, currentUser, kvItems } = Astro.props;
const currentLocale = locale as Locale;

const pageTitle = t(currentLocale, "admin.cache.title");
const filter = parseFilterParams(Astro.url.searchParams);
const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") ?? "1", 10) || 1);
const perPage = 20;

const getT = (key: string, fallback: string) => {
  const translated = t(currentLocale, key);
  return translated !== key ? translated : fallback;
};

const columns = [
  { key: "key", label: t(currentLocale, "admin.cache.key") },
  { key: "valuePreview", label: t(currentLocale, "admin.cache.valuePreview") },
];

const filteredKvItems = filterItemsClientSide(
  kvItems.map((item) => ({ key: item.key, valuePreview: item.valuePreview })),
  filter,
  columns.map((col) => col.key),
);
const total = filteredKvItems.length;
const totalPages = Math.max(1, Math.ceil(total / perPage));
const currentPage = Math.min(page, totalPages);
const start = (currentPage - 1) * perPage;
const end = start + perPage;
const listItems = filteredKvItems.slice(start, end);

const buildCacheUrl = (nextPage: number) =>
  buildUrlWithParams(Astro.url.pathname, Astro.url.searchParams, {
    page: String(nextPage),
  });

const filterClearHref = buildUrlWithParams(Astro.url.pathname, Astro.url.searchParams, {
  page: "1",
  filter_key: null,
  filter_valuePreview: null,
});

const cacheHiddenFields: Record<string, string> = {};
const domainParam = Astro.url.searchParams.get("domain");
if (domainParam) cacheHiddenFields["domain"] = domainParam;

const resetConfirm =
  t(currentLocale, "admin.cache.resetConfirm") !== "admin.cache.resetConfirm"
    ? t(currentLocale, "admin.cache.resetConfirm")
    : "Tem certeza que deseja resetar todo o cache? Todas as chaves serão removidas.";
const resetButtonLabel = t(currentLocale, "admin.cache.resetButton");
const previousLabel = getT("admin.list.previous", "Anterior");
const nextLabel = getT("admin.list.next", "Próxima");
const pageOfText = getT("admin.list.pageOf", "Página {page} de {totalPages} ({total} itens)")
  .replace("{page}", String(currentPage))
  .replace("{totalPages}", String(totalPages))
  .replace("{total}", String(total));
---

<AdminLayout title={pageTitle} locale={locale} menuItems={menuItems} user={currentUser}>
  <div slot="header-actions">
    <span class="text-sm text-base-content/70">{currentUser.email}</span>
  </div>

  <div class="p-6" x-data="{ loading: false }">
    <div class="flex flex-col gap-4">
      <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <div class="flex-1 min-w-0">
          <DataListPanel
            columns={columns}
            items={listItems}
            action={Astro.url.pathname}
            hiddenFields={cacheHiddenFields}
            filterValues={filter}
            filterPlaceholder={t(currentLocale, "admin.list.filter")}
            filterSubmitLabel={t(currentLocale, "admin.list.filterSubmit")}
            filterClearLabel={t(currentLocale, "admin.list.filterClear")}
            filterClearHref={filterClearHref}
            emptyMessage={t(currentLocale, "admin.cache.noItems")}
            emptyColspan={2}
            pagination={{
              page: currentPage,
              totalPages,
              total,
              buildPageUrl: (nextPage) => buildCacheUrl(nextPage),
            }}
            previousLabel={previousLabel}
            nextLabel={nextLabel}
            pageOfText={pageOfText}
          />
        </div>

        <button
          type="button"
          id="cache-reset-btn"
          class="btn btn-error text-white shrink-0"
          hx-get="/api/kv-clear"
          hx-trigger="click"
          hx-confirm={resetConfirm}
          hx-swap="none"
          @htmx:before-request="loading = true"
          @htmx:after-request="loading = false"
          :disabled="loading"
        >
          <span x-show="!loading" x-cloak>{resetButtonLabel}</span>
          <span x-show="loading" x-cloak>…</span>
        </button>
      </div>
    </div>
  </div>
</AdminLayout>
